<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Medlemskatalog - FilmCentrum Riks</title>
  <link href="https://fonts.googleapis.com/css2?family=Special+Elite&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
                *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#fafafa;color:#1e293b}
    .header{background:#fff;box-shadow:0 1px 2px 0 rgba(0,0,0,.05);position:sticky;top:0;z-index:50}
    .header-inner{max-width:80rem;margin:0 auto;padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:64px}
    @media(min-width:768px){.header-inner{height:80px}}
    .logo-link{display:flex;align-items:center;gap:12px;text-decoration:none}
    .logo-img{height:48px;width:auto}
    .logo-text{font-family:'Special Elite','Courier New',monospace;color:#c0392b;font-size:1.125rem;font-weight:700;letter-spacing:0.025em}
    .main-nav{display:none;align-items:center;gap:4px}
    @media(min-width:1024px){.main-nav{display:flex}}
    .main-nav a{color:#374151;text-decoration:none;font-size:0.875rem;font-weight:500;padding:8px 12px;border-radius:6px;transition:color 0.15s,background-color 0.15s;white-space:nowrap}
    .main-nav a:hover{color:#c0392b;background:#f9fafb}
    .header-actions{display:flex;align-items:center;gap:12px}
    .fc-dist-btn{display:none;background:#c0392b;color:#fff;text-decoration:none;font-size:0.875rem;font-weight:500;padding:8px 16px;border-radius:6px;transition:background 0.15s}
    @media(min-width:768px){.fc-dist-btn{display:inline-flex}}
    .fc-dist-btn:hover{background:#a93226}
    .mobile-menu-btn{display:block;padding:8px;color:#4b5563;background:none;border:none;cursor:pointer}
    .mobile-menu-btn:hover{color:#111827}
    @media(min-width:1024px){.mobile-menu-btn{display:none}}
    .mobile-nav{display:none;border-top:1px solid #e5e7eb;padding:16px 0}
    .mobile-nav.show{display:block}
    @media(min-width:1024px){.mobile-nav{display:none!important}}
    .mobile-nav a{display:block;padding:8px 12px;font-size:1rem;font-weight:500;color:#374151;text-decoration:none;border-radius:6px}
    .mobile-nav a:hover{background:#f9fafb;color:#c0392b}
    .hero{background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);padding:48px 32px;text-align:center;color:#fff}
    .hero h1{font-family:'Playfair Display',serif;font-size:36px;margin-bottom:12px}
    .hero p{color:#94a3b8;font-size:15px;max-width:600px;margin:0 auto 24px}
    .search-bar{max-width:500px;margin:0 auto;display:flex;gap:8px}
    .search-bar input{flex:1;padding:12px 18px;border:none;border-radius:8px;font-size:14px;outline:none;background:#0f172a;color:#e2e8f0;border:1px solid #334155}
    .search-bar input:focus{border-color:#dc2626}
    .search-bar select{padding:12px 14px;border:none;border-radius:8px;font-size:13px;background:#0f172a;color:#e2e8f0;border:1px solid #334155;cursor:pointer}
    .container{max-width:1100px;margin:0 auto;padding:32px 24px}
    .stats{display:flex;gap:16px;margin-bottom:24px;font-size:13px;color:#64748b}
    .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px}
    .member-card{background:#fff;border-radius:12px;padding:24px;border:1px solid #e2e8f0;transition:box-shadow 0.2s,transform 0.2s}
    .member-card{text-decoration:none;color:inherit;display:block;cursor:pointer}
    .member-card:hover{box-shadow:0 8px 24px rgba(0,0,0,0.08);transform:translateY(-2px)}
    .card-top{display:flex;gap:12px;align-items:center;margin-bottom:10px}
    .member-photo{width:56px;height:56px;border-radius:50%;object-fit:cover;flex-shrink:0}
    .member-photo-placeholder{width:56px;height:56px;border-radius:50%;background:#c0392b;color:#fff;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;flex-shrink:0}
    .view-profile{margin-top:12px;font-size:13px;color:#c0392b;font-weight:500}
    .member-card h3{font-size:16px;font-weight:600;margin-bottom:4px}
    .member-card .headline{font-size:13px;color:#dc2626;margin-bottom:8px}
    .member-card .location{font-size:12px;color:#64748b;margin-bottom:10px}
    .member-card .branches{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px}
    .member-card .branch-tag{padding:2px 8px;background:#fef2f2;color:#dc2626;border-radius:12px;font-size:11px;font-weight:500}
    .member-card .bio{font-size:12px;color:#475569;line-height:1.5;max-height:48px;overflow:hidden}
    .member-card .links{margin-top:10px;display:flex;gap:8px}
    .member-card .links a{font-size:11px;color:#1d4ed8;text-decoration:none}
    .member-card .links a:hover{text-decoration:underline}
    .no-results{text-align:center;padding:48px;color:#64748b;font-size:15px}
    .footer{background:#1a1a2e;padding:24px 32px;text-align:center;color:#64748b;font-size:12px;margin-top:48px}
    .footer a{color:#dc2626;text-decoration:none}
    @media(max-width:600px){.grid{grid-template-columns:1fr}.search-bar{flex-direction:column}}
  </style>
</head>
<body>
    <div class="header">
    <div class="header-inner">
      <a href="/filmcentrum/" class="logo-link">
        <img src="/filmcentrum/fc-logo.png" alt="FilmCentrum" class="logo-img">
        <span class="logo-text">FILMCENTRUM RIKS</span>
      </a>
      <nav class="main-nav">
        <a href="/filmcentrum/">Hem</a>
        <a href="/filmcentrum/om-oss">Om oss</a>
        <a href="/filmcentrum/styrelse">Styrelse</a>
        <a href="/filmcentrum/styrelse">Styrelse</a>
      <a href="/filmcentrum/openthedoors">FC OpenTheDoors</a>
        <a href="/filmcentrum/medlemskap">Medlemskap</a>
        <a href="/filmcentrum/nyheter">Nyheter</a>
        <a href="/filmcentrum/kontakt">Kontakta oss</a>
        <a href="/filmcentrum/login">Logga in</a>
        <a href="/fai/">Festival AI</a>
        <a href="/filmcentrum/kalender">Kalender</a>
      </nav>
      <div class="header-actions">
        <a href="/fc/" class="fc-dist-btn">FC Distribution</a>
        <button class="mobile-menu-btn" onclick="document.querySelector('.mobile-nav').classList.toggle('show')" aria-label="Meny">
          <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
    <div class="mobile-nav">
      <a href="/filmcentrum/">Hem</a>
      <a href="/filmcentrum/om-oss">Om oss</a>
      <a href="/filmcentrum/styrelse">Styrelse</a>
        <a href="/filmcentrum/openthedoors">FC OpenTheDoors</a>
      <a href="/filmcentrum/medlemskap">Medlemskap</a>
      <a href="/filmcentrum/nyheter">Nyheter</a>
      <a href="/filmcentrum/kontakt">Kontakta oss</a>
      <a href="/filmcentrum/login">Logga in</a>
        <a href="/fai/">Festival AI</a>
        <a href="/filmcentrum/kalender">Kalender</a>
    </div>
  </div>

  <div class="hero">
    <h1>Medlemskatalog</h1>
    <p>Sok och hitta filmskapare, regissorer, producenter, fotografer och kulturarbetare. Sok pa namn, yrke eller stad.</p>
    <div class="search-bar">
      <input type="text" id="searchInput" placeholder="Sok namn, yrke, stad..." oninput="filterMembers()">
    </div>
    <div class="search-bar" style="margin-top:8px;">
      <select id="branchFilter" onchange="filterMembers()">
        <option value="">Alla filmgrenar</option>
        <% branches.forEach(function(b) { %>
          <option value="<%= b.name_sv || b.name %>"><%= b.name_sv || b.name %></option>
        <% }); %>
      </select>
      <select id="cityFilter" onchange="filterMembers()">
        <option value="">Alla stader</option>
      </select>
    </div>
  </div>

  <div class="container">
    <div class="stats" id="statsBar"><%= members.length %> medlemmar</div>
    <div class="grid" id="membersGrid">
      <% if (members.length === 0) { %>
        <div class="no-results">Inga medlemmar att visa annu.</div>
      <% } %>
      <% members.forEach(function(m) { %>
        <a href="/filmcentrum/members/<%= m.profile_slug || m.id %>" class="member-card" data-name="<%= (m.name || '').toLowerCase() %>" data-branches="<%= (m.branch_names || '').toLowerCase() %>" data-city="<%= (m.city || '').toLowerCase() %>" data-profession="<%= (m.headline || m.profession || '').toLowerCase() %>">
          <div class="card-top">
            <% if (m.profile_photo) { %><img src="<%= m.profile_photo %>" class="member-photo" alt=""><% } else { %><div class="member-photo-placeholder"><%= (m.name || 'M').charAt(0) %></div><% } %>
            <div>
              <h3><%= m.name %><% if (m.stage_name) { %> <span style="font-weight:400;color:#64748b;font-size:13px;">(<%= m.stage_name %>)</span><% } %></h3>
              <% if (m.headline || m.profession) { %><div class="headline"><%= m.headline || m.profession %></div><% } %>
              <% if (m.city) { %><div class="location"><%= m.city %><% if (m.country && m.country !== 'SE') { %>, <%= m.country %><% } %></div><% } %>
            </div>
          </div>
          <% if (m.branch_names) { %>
            <div class="branches">
              <% m.branch_names.split(',').forEach(function(bn) { if(bn.trim()) { %>
                <span class="branch-tag"><%= bn.trim() %></span>
              <% } }); %>
            </div>
          <% } %>
          <% if (m.biography) { %><div class="bio"><%= m.biography.substring(0, 120) %><%= m.biography.length > 120 ? '...' : '' %></div><% } %>
          <div class="view-profile">Visa profil &rarr;</div>
        </a>
      <% }); %>
    </div>
  </div>

  <div class="footer">
    &copy; 2026 <a href="/filmcentrum/">FilmCentrum Riks</a> - Sveriges filmkooperativ
  </div>

<script>
// Populate city filter
var cities = new Set();
document.querySelectorAll('.member-card').forEach(function(c) {
  var city = c.getAttribute('data-city');
  if (city) cities.add(city);
});
var citySelect = document.getElementById('cityFilter');
Array.from(cities).sort().forEach(function(city) {
  var opt = document.createElement('option');
  opt.value = city;
  opt.textContent = city.charAt(0).toUpperCase() + city.slice(1);
  citySelect.appendChild(opt);
});

function filterMembers() {
  var q = document.getElementById('searchInput').value.toLowerCase().trim();
  var branch = document.getElementById('branchFilter').value.toLowerCase();
  var city = document.getElementById('cityFilter').value.toLowerCase();
  var cards = document.querySelectorAll('.member-card');
  var shown = 0;
  cards.forEach(function(c) {
    var name = c.getAttribute('data-name') || '';
    var prof = c.getAttribute('data-profession') || '';
    var loc = c.getAttribute('data-city') || '';
    var branches = c.getAttribute('data-branches') || '';
    var textMatch = !q || name.indexOf(q) !== -1 || prof.indexOf(q) !== -1 || loc.indexOf(q) !== -1;
    var branchMatch = !branch || branches.indexOf(branch) !== -1;
    var cityMatch = !city || loc === city;
    if (textMatch && branchMatch && cityMatch) { c.style.display = ''; shown++; }
    else { c.style.display = 'none'; }
  });
  document.getElementById('statsBar').textContent = shown + ' medlemmar' + (q || branch || city ? ' (filtrerade)' : '');
}
</script>
<script>
(function(){
  var cal = document.createElement('div');
  cal.id = 'fc-events-sidebar';
  cal.innerHTML = '<div style="position:fixed;top:100px;right:16px;width:280px;max-height:70vh;overflow-y:auto;background:#fff;border-radius:12px;box-shadow:0 4px 24px rgba(0,0,0,0.1);border:1px solid #e2e8f0;z-index:40;font-family:Inter,sans-serif;display:none;" id="evSidebar"><div style="padding:14px 16px;border-bottom:1px solid #f1f5f9;display:flex;justify-content:space-between;align-items:center;"><strong style="font-size:14px;color:#1e293b;">Kommande evenemang</strong><span style="cursor:pointer;font-size:18px;color:#94a3b8;" onclick="document.getElementById(\'evSidebar\').style.display=\'none\';document.getElementById(\'evToggle\').style.display=\'flex\';">&times;</span></div><div id="evList" style="padding:12px 16px;"></div><div style="padding:12px 16px;border-top:1px solid #f1f5f9;text-align:center;"><a href="/fai/" style="color:#c0392b;text-decoration:none;font-size:13px;font-weight:500;">Festival AI &rarr;</a></div></div>';
  // Auto-show sidebar on desktop
  if(window.innerWidth > 1024) { document.getElementById('evSidebar').style.display='block'; document.getElementById('evToggle').style.display='none'; loadEvents(); }
  cal.innerHTML += '<div id="evToggle" style="position:fixed;top:100px;right:16px;width:44px;height:44px;background:#c0392b;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 12px rgba(192,57,43,0.3);z-index:40;" onclick="document.getElementById(\'evSidebar\').style.display=\'block\';this.style.display=\'none\';loadEvents();"><svg width="22" height="22" fill="#fff" viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z"/></svg></div>';
  document.body.appendChild(cal);
  window.loadEvents = function() {
    fetch('/filmcentrum/admin/api/public/events').then(function(r){return r.json()}).then(function(d){
      var html = '';
      if (d.events && d.events.length > 0) {
        d.events.slice(0, 8).forEach(function(e){
          var cat = e.category === 'festival' ? '#3b82f6' : e.category === 'workshop' ? '#10b981' : '#8b5cf6';
          html += '<div style="padding:8px 0;border-bottom:1px solid #f8fafc;"><div style="display:flex;gap:8px;align-items:flex-start;"><div style="min-width:40px;text-align:center;background:#fef2f2;border-radius:6px;padding:4px;"><div style="font-size:10px;color:#c0392b;font-weight:600;">' + (e.event_date||'').substring(5,7) + '</div><div style="font-size:16px;font-weight:700;color:#1e293b;">' + (e.event_date||'').substring(8,10) + '</div></div><div><div style="font-size:13px;font-weight:600;color:#1e293b;">' + e.title + '</div><div style="font-size:11px;color:#64748b;">' + (e.location||'') + '</div><span style="display:inline-block;padding:1px 6px;background:' + cat + '20;color:' + cat + ';border-radius:8px;font-size:10px;margin-top:2px;">' + e.category + '</span></div></div></div>';
        });
      } else {
        html = '<p style="color:#94a3b8;font-size:13px;text-align:center;padding:16px;">Inga kommande evenemang.</p>';
      }
      document.getElementById('evList').innerHTML = html;
    }).catch(function(){
      document.getElementById('evList').innerHTML = '<p style="color:#94a3b8;font-size:13px;">Kunde inte ladda evenemang.</p>';
    });
  };
})();
</script>
<script src="/filmcentrum/chatbot.js"></script>
</body>
</html>
