<style>
  .cb-section{background:#1e293b;border-radius:10px;padding:24px;border:1px solid #334155;margin-bottom:20px}
  .cb-section h3{font-size:16px;color:#dc2626;margin-bottom:16px;border-bottom:1px solid #334155;padding-bottom:8px}
  .cb-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
  .cb-group{display:flex;flex-direction:column}
  .cb-group label{font-size:12px;color:#94a3b8;margin-bottom:4px;font-weight:500}
  .cb-group input,.cb-group select,.cb-group textarea{padding:8px 12px;background:#0f172a;border:1px solid #334155;border-radius:6px;color:#e2e8f0;font-size:13px;outline:none}
  .cb-group input:focus,.cb-group select:focus,.cb-group textarea:focus{border-color:#dc2626}
  .cb-group textarea{min-height:100px;resize:vertical;font-family:inherit}
  .cb-group input[type=color]{height:40px;padding:4px;cursor:pointer}
  .btn-save{padding:12px 32px;background:#dc2626;color:#fff;border:none;border-radius:6px;font-size:14px;font-weight:600;cursor:pointer;margin-top:16px}
  .btn-save:hover{background:#b91c1c}
  .success-msg{background:#064e3b;color:#6ee7b7;padding:12px 20px;border-radius:8px;margin-bottom:16px;font-size:14px}
  .toggle-switch{position:relative;display:inline-block;width:50px;height:26px}
  .toggle-switch input{opacity:0;width:0;height:0}
  .toggle-slider{position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background:#334155;border-radius:26px;transition:.3s}
  .toggle-slider:before{position:absolute;content:"";height:20px;width:20px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.3s}
  .toggle-switch input:checked + .toggle-slider{background:#dc2626}
  .toggle-switch input:checked + .toggle-slider:before{transform:translateX(24px)}
  .preview-chat{background:#1e293b;border-radius:12px;padding:0;overflow:hidden;max-width:360px;margin-top:16px;border:1px solid #334155}
  .preview-header{padding:14px 18px;display:flex;justify-content:space-between;align-items:center}
  .preview-header span{color:#fff;font-weight:600;font-size:14px}
  .preview-body{padding:16px;height:150px;background:#0f172a}
  .preview-msg{background:#1e293b;color:#e2e8f0;padding:10px 14px;border-radius:12px 12px 12px 4px;font-size:13px;max-width:85%;display:inline-block}
  .preview-input{padding:12px;border-top:1px solid #334155;display:flex;gap:8px}
  .preview-input input{flex:1;padding:8px 12px;background:#0f172a;border:1px solid #334155;border-radius:6px;color:#e2e8f0;font-size:12px}
  .preview-input button{padding:8px 14px;border:none;border-radius:6px;color:#fff;font-size:12px;cursor:pointer}
</style>

<h2 style="font-size:20px;color:#f1f5f9;margin-bottom:20px;">Chatbot Settings</h2>

<% if (success) { %><div class="success-msg">Chatbot settings saved.</div><% } %>

<form method="POST" action="<%= base %>/chatbot-settings">

  <div class="cb-section">
    <h3>General</h3>
    <div class="cb-grid">
      <div class="cb-group">
        <label>Chatbot Enabled</label>
        <label class="toggle-switch">
          <input type="checkbox" name="chatbot_enabled" value="1" <%= cb.chatbot_enabled === '1' ? 'checked' : '' %>>
          <span class="toggle-slider"></span>
        </label>
      </div>
      <div class="cb-group">
        <label>Chatbot Name</label>
        <input type="text" name="chatbot_name" value="<%= cb.chatbot_name || 'FilmCentrum Support' %>">
      </div>
      <div class="cb-group">
        <label>Button Color</label>
        <div style="display:flex;gap:8px;align-items:center;">
          <input type="color" name="chatbot_color" value="<%= cb.chatbot_color || '#dc2626' %>" style="width:60px;">
          <input type="text" name="chatbot_color_hex" value="<%= cb.chatbot_color || '#dc2626' %>" style="width:100px;" oninput="this.previousElementSibling.value=this.value">
        </div>
      </div>
      <div class="cb-group">
        <label>Position</label>
        <select name="chatbot_position">
          <option value="right" <%= cb.chatbot_position === 'right' ? 'selected' : '' %>>Bottom Right</option>
          <option value="left" <%= cb.chatbot_position === 'left' ? 'selected' : '' %>>Bottom Left</option>
        </select>
      </div>
    </div>
  </div>

  <div class="cb-section">
    <h3>Messages</h3>
    <div class="cb-grid">
      <div class="cb-group">
        <label>Welcome Message</label>
        <textarea name="chatbot_welcome"><%= cb.chatbot_welcome || 'Hej! Valkommen till FilmCentrum Riks. Hur kan jag hjalpa dig?' %></textarea>
      </div>
      <div class="cb-group">
        <label>Input Placeholder</label>
        <input type="text" name="chatbot_placeholder" value="<%= cb.chatbot_placeholder || 'Skriv ett meddelande...' %>">
      </div>
    </div>
  </div>

  <div class="cb-section">
    <h3>AI Knowledge Base</h3>
    <div class="cb-group">
      <label>Custom Context (extra information the chatbot should know - add anything specific about your organization)</label>
      <textarea name="chatbot_custom_context" style="min-height:150px;" placeholder="Example: Vi har oppet mandag-fredag 9-17. Vart kontor ligger pa Bredgrand 2. Vara oppettider ar..."><%= cb.chatbot_custom_context || '' %></textarea>
      <small style="color:#64748b;margin-top:4px;">The chatbot already knows about membership, pricing, members, news, and pages from the website. Add any additional info here.</small>
    </div>
  </div>

  <div class="cb-section">
    <h3>Preview</h3>
    <div class="preview-chat">
      <div class="preview-header" id="previewHeader" style="background:<%= cb.chatbot_color || '#dc2626' %>">
        <span><%= cb.chatbot_name || 'FilmCentrum Support' %></span>
        <span style="color:#fff;font-size:20px;">&times;</span>
      </div>
      <div class="preview-body">
        <div class="preview-msg"><%= cb.chatbot_welcome || 'Hej! Valkommen till FilmCentrum Riks.' %></div>
      </div>
      <div class="preview-input">
        <input type="text" value="" placeholder="<%= cb.chatbot_placeholder || 'Skriv ett meddelande...' %>" disabled>
        <button style="background:<%= cb.chatbot_color || '#dc2626' %>">Skicka</button>
      </div>
    </div>
  </div>

  <button type="submit" class="btn-save">Save Chatbot Settings</button>
</form>
