<style>
  .back-link { display: inline-block; margin-bottom: 16px; color: #94a3b8; text-decoration: none; font-size: 13px; }
  .back-link:hover { color: #dc2626; }
  .success-banner { background: #064e3b; color: #6ee7b7; padding: 12px 20px; border-radius: 8px; margin-bottom: 16px; font-size: 14px; }
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 8px; }
  .page-header h2 { font-size: 20px; color: #f1f5f9; }
  .page-header .slug-info { font-size: 13px; color: #64748b; font-family: monospace; }
  .title-row { display: flex; gap: 12px; margin-bottom: 16px; }
  .title-row .form-group { flex: 1; }
  .title-row .form-group label { display: block; font-size: 12px; color: #94a3b8; margin-bottom: 4px; }
  .title-row .form-group input { width: 100%; padding: 8px 12px; background: #0f172a; border: 1px solid #334155; border-radius: 6px; color: #e2e8f0; font-size: 13px; outline: none; }
  .title-row .form-group input:focus { border-color: #dc2626; }
  .lang-tabs { display: flex; gap: 0; margin-bottom: 0; }
  .lang-tab { padding: 8px 20px; font-size: 13px; font-weight: 600; border: 1px solid #334155; background: #1a2332; color: #64748b; cursor: pointer; border-bottom: none; }
  .lang-tab:first-child { border-radius: 6px 0 0 0; }
  .lang-tab:last-child { border-radius: 0 6px 0 0; }
  .lang-tab.active { background: #dc2626; color: #fff; border-color: #dc2626; }
  .editor-container { border: 1px solid #334155; border-radius: 0 0 8px 8px; overflow: hidden; margin-bottom: 16px; }
  .gjs-one-bg { background: #1e293b !important; }
  .gjs-two-color { color: #e2e8f0 !important; }
  .gjs-three-bg { background: #0f172a !important; }
  .gjs-four-color, .gjs-four-color-h:hover { color: #dc2626 !important; }
  .btn-save { padding: 10px 32px; background: #dc2626; color: #fff; border: none; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer; }
  .btn-save:hover { background: #b91c1c; }
  .btn-secondary { padding: 10px 20px; background: #334155; color: #e2e8f0; border: none; border-radius: 6px; font-size: 13px; cursor: pointer; text-decoration: none; display: inline-block; margin-left: 8px; }
  .btn-secondary:hover { background: #475569; }
  .actions-bar { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
</style>

<a href="<%= base %>/pages" class="back-link">&larr; Back to Pages</a>

<% if (success) { %>
  <div class="success-banner">Page saved successfully.</div>
<% } %>

<div class="page-header">
  <div>
    <h2>Edit Page</h2>
    <div class="slug-info">/<%= page.slug %></div>
  </div>
</div>

<form method="POST" action="<%= base %>/pages/<%= page.id %>" id="pageForm">
  <div class="title-row">
    <div class="form-group"><label>Title (SV)</label><input type="text" name="title_sv" value="<%= page.title_sv || '' %>"></div>
    <div class="form-group"><label>Title (EN)</label><input type="text" name="title_en" value="<%= page.title_en || '' %>"></div>
  </div>

  <div class="lang-tabs">
    <div class="lang-tab active" onclick="switchLang('sv')">Svenska</div>
    <div class="lang-tab" onclick="switchLang('en')">English</div>
  </div>

  <div id="editor-sv" class="editor-container" style="height:520px;"></div>
  <div id="editor-en" class="editor-container" style="height:520px;display:none;"></div>

  <textarea name="content_sv" id="hidden_sv" style="display:none;"><%= page.content_sv || '' %></textarea>
  <textarea name="content_en" id="hidden_en" style="display:none;"><%= page.content_en || '' %></textarea>

  <div class="actions-bar">
    <button type="submit" class="btn-save" onclick="saveEditors()">Save Page</button>
    <a href="<%= base %>/pages" class="btn-secondary">Cancel</a>
  </div>
</form>

<link rel="stylesheet" href="https://unpkg.com/grapesjs@0.21.10/dist/css/grapes.min.css">
<link rel="stylesheet" href="https://unpkg.com/grapesjs-preset-webpage@1.0.3/dist/grapesjs-preset-webpage.min.css">
<script src="https://unpkg.com/grapesjs@0.21.10/dist/grapes.min.js"></script>
<script src="https://unpkg.com/grapesjs-preset-webpage@1.0.3/dist/grapesjs-preset-webpage.min.js"></script>

<script>
var currentLang = 'sv';
var editors = {};

function initEditor(lang) {
  var container = document.getElementById('editor-' + lang);
  var content = document.getElementById('hidden_' + lang).value || '<p>Start editing...</p>';

  editors[lang] = grapesjs.init({
    container: '#editor-' + lang,
    height: '520px',
    width: 'auto',
    storageManager: false,
    plugins: ['gjs-preset-webpage'],
    pluginsOpts: { 'gjs-preset-webpage': { blocksBasicOpts: { flexGrid: true }, navbarOpts: false, countdownOpts: false, formsOpts: false } },
    canvas: { styles: [
      'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap'
    ]},
    components: content,
    styleManager: {
      sectors: [{
        name: 'Typography',
        open: true,
        properties: [
          { name: 'Font Family', property: 'font-family', type: 'select',
            options: [
              {id:'Inter, sans-serif', label:'Inter'},
              {id:'Playfair Display, serif', label:'Playfair Display'},
              {id:'Arial, sans-serif', label:'Arial'},
              {id:'Georgia, serif', label:'Georgia'},
              {id:'Verdana, sans-serif', label:'Verdana'},
              {id:'Times New Roman, serif', label:'Times New Roman'},
              {id:'Courier New, monospace', label:'Courier New'},
            ]},
          { name: 'Font Size', property: 'font-size', type: 'slider', min: 10, max: 72, step: 1, units: ['px','em','rem'] },
          { name: 'Font Weight', property: 'font-weight', type: 'select',
            options: [{id:'300',label:'Light'},{id:'400',label:'Normal'},{id:'500',label:'Medium'},{id:'600',label:'Semi Bold'},{id:'700',label:'Bold'}] },
          { name: 'Color', property: 'color', type: 'color' },
          { name: 'Line Height', property: 'line-height', type: 'slider', min: 1, max: 3, step: 0.1 },
          { name: 'Letter Spacing', property: 'letter-spacing', type: 'slider', min: -2, max: 10, step: 0.5, units: ['px'] },
          { name: 'Text Align', property: 'text-align', type: 'radio', options: [{id:'left',label:'L'},{id:'center',label:'C'},{id:'right',label:'R'},{id:'justify',label:'J'}] },
          { name: 'Text Transform', property: 'text-transform', type: 'select', options: [{id:'none',label:'None'},{id:'uppercase',label:'Uppercase'},{id:'lowercase',label:'Lowercase'},{id:'capitalize',label:'Capitalize'}] },
        ]
      },{
        name: 'Spacing',
        properties: [
          { name: 'Margin', property: 'margin', type: 'composite', properties: [
            {name:'Top',property:'margin-top',type:'integer',units:['px','%']},
            {name:'Right',property:'margin-right',type:'integer',units:['px','%']},
            {name:'Bottom',property:'margin-bottom',type:'integer',units:['px','%']},
            {name:'Left',property:'margin-left',type:'integer',units:['px','%']}
          ]},
          { name: 'Padding', property: 'padding', type: 'composite', properties: [
            {name:'Top',property:'padding-top',type:'integer',units:['px','%']},
            {name:'Right',property:'padding-right',type:'integer',units:['px','%']},
            {name:'Bottom',property:'padding-bottom',type:'integer',units:['px','%']},
            {name:'Left',property:'padding-left',type:'integer',units:['px','%']}
          ]}
        ]
      },{
        name: 'Background',
        properties: [
          { name: 'Background Color', property: 'background-color', type: 'color' },
          { name: 'Background Image', property: 'background-image', type: 'file' },
          { name: 'Border Radius', property: 'border-radius', type: 'slider', min: 0, max: 50, units: ['px','%'] },
        ]
      },{
        name: 'Dimension',
        properties: [
          { name: 'Width', property: 'width', type: 'integer', units: ['px','%','vw'] },
          { name: 'Max Width', property: 'max-width', type: 'integer', units: ['px','%'] },
          { name: 'Height', property: 'height', type: 'integer', units: ['px','vh','auto'] },
        ]
      }]
    },
    blockManager: {
      blocks: [
        { id: 'heading', label: 'Heading', category: 'Basic', content: '<h2 style="font-family:Playfair Display,serif;font-size:28px;font-weight:700;margin-bottom:16px;">Rubrik</h2>' },
        { id: 'paragraph', label: 'Text', category: 'Basic', content: '<p style="font-size:15px;line-height:1.7;margin-bottom:12px;">Skriv text har...</p>' },
        { id: 'image', label: 'Image', category: 'Basic', content: { type: 'image' } },
        { id: 'link', label: 'Link', category: 'Basic', content: '<a href="#" style="color:#dc2626;text-decoration:underline;">Lank</a>' },
        { id: 'button', label: 'Button', category: 'Basic', content: '<a href="#" style="display:inline-block;padding:12px 28px;background:#dc2626;color:#fff;border-radius:6px;text-decoration:none;font-weight:600;font-size:14px;">Knapp</a>' },
        { id: 'divider', label: 'Divider', category: 'Basic', content: '<hr style="border:none;border-top:1px solid #e2e8f0;margin:24px 0;">' },
        { id: 'list', label: 'List', category: 'Basic', content: '<ul style="padding-left:20px;margin-bottom:16px;"><li>Punkt 1</li><li>Punkt 2</li><li>Punkt 3</li></ul>' },
        { id: 'section', label: 'Section', category: 'Layout', content: '<section style="padding:40px 24px;"><div style="max-width:900px;margin:0 auto;"><h2>Section</h2><p>Content</p></div></section>' },
        { id: 'columns', label: '2 Columns', category: 'Layout', content: '<div style="display:flex;gap:24px;flex-wrap:wrap;"><div style="flex:1;min-width:250px;"><p>Column 1</p></div><div style="flex:1;min-width:250px;"><p>Column 2</p></div></div>' },
        { id: 'cols3', label: '3 Columns', category: 'Layout', content: '<div style="display:flex;gap:20px;flex-wrap:wrap;"><div style="flex:1;min-width:200px;"><p>Col 1</p></div><div style="flex:1;min-width:200px;"><p>Col 2</p></div><div style="flex:1;min-width:200px;"><p>Col 3</p></div></div>' },
        { id: 'card', label: 'Card', category: 'Components', content: '<div style="background:#fff;border-radius:12px;padding:24px;border:1px solid #e2e8f0;box-shadow:0 2px 8px rgba(0,0,0,0.05);"><h3 style="margin-bottom:8px;">Card Title</h3><p style="color:#64748b;font-size:14px;">Card content</p></div>' },
        { id: 'video', label: 'Video', category: 'Components', content: { type: 'video' } },
        { id: 'quote', label: 'Quote', category: 'Components', content: '<blockquote style="border-left:4px solid #dc2626;padding:16px 20px;margin:16px 0;font-style:italic;color:#475569;background:#f8fafc;border-radius:0 8px 8px 0;"><p>Citat har...</p></blockquote>' },
      ]
    }
  });
}

initEditor('sv');
initEditor('en');

function switchLang(lang) {
  currentLang = lang;
  document.querySelectorAll('.lang-tab').forEach(function(t, i) {
    t.classList.toggle('active', (i === 0 && lang === 'sv') || (i === 1 && lang === 'en'));
  });
  document.getElementById('editor-sv').style.display = lang === 'sv' ? 'block' : 'none';
  document.getElementById('editor-en').style.display = lang === 'en' ? 'block' : 'none';
  if (editors[lang]) editors[lang].refresh();
}

function saveEditors() {
  ['sv', 'en'].forEach(function(lang) {
    if (editors[lang]) {
      var html = editors[lang].getHtml();
      var css = editors[lang].getCss();
      var fullContent = css ? '<style>' + css + '</style>' + html : html;
      document.getElementById('hidden_' + lang).value = fullContent;
    }
  });
}

document.getElementById('pageForm').addEventListener('submit', function() { saveEditors(); });
</script>
