<link rel="stylesheet" href="https://unpkg.com/grapesjs@0.21.10/dist/css/grapes.min.css">
<style>
  .back-link{display:inline-block;margin-bottom:16px;color:#94a3b8;text-decoration:none;font-size:13px}.back-link:hover{color:#dc2626}
  .compose-card{background:#1e293b;border-radius:10px;padding:24px;border:1px solid #334155;margin-bottom:16px}
  .compose-card h2{font-size:18px;color:#dc2626;margin-bottom:16px}
  .form-group{margin-bottom:14px}.form-group label{display:block;font-size:12px;color:#94a3b8;margin-bottom:4px;font-weight:500}
  .form-group input,.form-group select{width:100%;padding:9px 12px;background:#0f172a;border:1px solid #334155;border-radius:6px;color:#e2e8f0;font-size:13px;outline:none}
  .form-group input:focus,.form-group select:focus{border-color:#dc2626}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .stats-bar{display:flex;gap:16px;margin-bottom:16px}.stat-item{background:#0f172a;border:1px solid #334155;border-radius:8px;padding:12px 16px;text-align:center;flex:1}.stat-item .num{font-size:24px;font-weight:700;color:#dc2626}.stat-item .label{font-size:11px;color:#64748b;text-transform:uppercase}
  .template-btns{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
  .tmpl-btn{padding:6px 14px;background:#0f172a;border:1px solid #334155;border-radius:6px;color:#94a3b8;font-size:12px;cursor:pointer}.tmpl-btn:hover{border-color:#dc2626;color:#e2e8f0}
  .editor-container{border:1px solid #334155;border-radius:8px;overflow:hidden;margin-bottom:14px}
  .btn-send{padding:12px 32px;background:#dc2626;color:#fff;border:none;border-radius:6px;font-size:14px;font-weight:600;cursor:pointer}.btn-send:hover{background:#b91c1c}
  .btn-preview{padding:12px 24px;background:#334155;color:#e2e8f0;border:none;border-radius:6px;font-size:14px;cursor:pointer;margin-left:8px}.btn-preview:hover{background:#475569}
  .ai-bar{display:flex;gap:6px;flex-wrap:wrap;padding:8px 12px;background:#0f172a;border:1px solid #334155;border-radius:8px;margin-bottom:14px}
  .ai-bar .ai-label{font-size:11px;color:#dc2626;font-weight:700;display:flex;align-items:center;margin-right:4px}
  .ai-btn{padding:5px 12px;font-size:11px;border:1px solid #334155;border-radius:4px;cursor:pointer;color:#94a3b8;background:#1e293b}.ai-btn:hover{border-color:#dc2626;color:#e2e8f0}
  .ai-btn.loading{opacity:0.5;pointer-events:none}
  .ai-input{flex:1;min-width:180px;padding:5px 10px;background:#1e293b;border:1px solid #334155;border-radius:4px;color:#e2e8f0;font-size:11px}
  .preview-modal{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.8);z-index:1000;justify-content:center;align-items:center}.preview-modal.show{display:flex}
  .preview-content{background:#fff;color:#333;max-width:600px;width:90%;max-height:80vh;overflow-y:auto;border-radius:8px;padding:32px}
  .preview-close{position:absolute;top:20px;right:30px;color:#fff;font-size:28px;cursor:pointer}
</style>

<a href="<%= base %>/newsletter" class="back-link">&larr; Back to Newsletter</a>

<div class="stats-bar">
  <div class="stat-item"><div class="num"><%= stats.active %></div><div class="label">Active Subscribers</div></div>
  <div class="stat-item"><div class="num"><%= stats.total %></div><div class="label">Total</div></div>
</div>

<form method="POST" action="<%= base %>/newsletter/send" id="composeForm">
  <div class="compose-card">
    <h2>Compose Newsletter</h2>
    <div class="form-row">
      <div class="form-group"><label>Recipients</label>
        <select name="recipients">
          <option value="all_subscribers">All Active Subscribers</option>
          <option value="paid_members">Paid Members Only</option>
          <option value="active_members">Active Members</option>
          <option value="pending_members">Pending Members</option>
          <option value="all_members">All Members</option>
        </select>
      </div>
      <div class="form-group"><label>Subject</label><input type="text" name="subject" id="nlSubject" required placeholder="Newsletter subject..."></div>
    </div>
  </div>

  <div class="compose-card">
    <h2>Template</h2>
    <div class="template-btns">
      <button type="button" class="tmpl-btn" onclick="loadTmpl('news')">News Update</button>
      <button type="button" class="tmpl-btn" onclick="loadTmpl('event')">Event Invite</button>
      <button type="button" class="tmpl-btn" onclick="loadTmpl('welcome')">Welcome</button>
      <button type="button" class="tmpl-btn" onclick="loadTmpl('update')">Member Update</button>
      <button type="button" class="tmpl-btn" onclick="loadTmpl('minimal')">Minimal</button>
    </div>
    <div id="nlEditor" class="editor-container" style="height:450px;"></div>
    <textarea name="content" id="nlHidden" style="display:none;"></textarea>
  </div>

  <div class="ai-bar">
    <span class="ai-label">AI</span>
    <button type="button" class="ai-btn" onclick="nlAi('improve')">Improve</button>
    <button type="button" class="ai-btn" onclick="nlAi('expand')">Expand</button>
    <button type="button" class="ai-btn" onclick="nlAi('proofread')">Proofread</button>
    <button type="button" class="ai-btn" onclick="nlAi('translate_en')">EN</button>
    <button type="button" class="ai-btn" onclick="nlAi('translate_sv')">SV</button>
    <input type="text" class="ai-input" id="nlAiPrompt" placeholder="Generate: e.g. Write newsletter about upcoming workshop...">
    <button type="button" class="ai-btn" onclick="nlAi('generate')" style="background:#dc2626;color:#fff;border-color:#dc2626">Generate</button>
  </div>

  <button type="submit" class="btn-send" onclick="return confirmSend()">Send Newsletter</button>
  <button type="button" class="btn-preview" onclick="showPreview()">Preview</button>
</form>

<div class="preview-modal" id="previewModal">
  <span class="preview-close" onclick="closePreview()">&times;</span>
  <div class="preview-content" id="previewBody"></div>
</div>

<script src="https://unpkg.com/grapesjs@0.21.10/dist/grapes.min.js"></script>
<script src="https://unpkg.com/grapesjs-preset-webpage@1.0.3/dist/grapesjs-preset-webpage.min.js"></script>
<script>
var BASE_URL = '<%= base %>';
var templates = {
  news: '<div style="max-width:600px;margin:0 auto;font-family:Arial,sans-serif;"><div style="background:#dc2626;padding:24px;text-align:center;"><h1 style="color:#fff;font-size:24px;margin:0;">FilmCentrum Riks</h1><p style="color:#fecaca;font-size:13px;margin:4px 0 0;">Nyhetsbrev</p></div><div style="padding:32px 24px;background:#fff;"><h2 style="color:#1e293b;font-size:20px;">Rubrik</h2><p style="color:#374151;line-height:1.7;">Innehall...</p></div><div style="padding:16px 24px;background:#f1f5f9;text-align:center;font-size:12px;color:#64748b;">FilmCentrum Riks | filmcentrum.se</div></div>',
  event: '<div style="max-width:600px;margin:0 auto;font-family:Arial,sans-serif;"><div style="background:#1a1a2e;padding:32px;text-align:center;"><h1 style="color:#dc2626;font-size:28px;">Inbjudan</h1></div><div style="padding:32px 24px;background:#fff;"><h2>Evenemang</h2><p><strong>Datum:</strong> </p><p><strong>Tid:</strong> </p><p><strong>Plats:</strong> </p><p>Beskrivning...</p><a href="#" style="display:inline-block;padding:12px 28px;background:#dc2626;color:#fff;border-radius:6px;text-decoration:none;margin-top:16px;">Anmal dig</a></div></div>',
  welcome: '<div style="max-width:600px;margin:0 auto;font-family:Arial,sans-serif;"><div style="background:#dc2626;padding:32px;text-align:center;"><h1 style="color:#fff;">Valkommen!</h1></div><div style="padding:32px 24px;background:#fff;"><h2>Valkommen som medlem</h2><p>Vi ar glada att du blivit en del av FilmCentrum Riks.</p><h3>Vad du kan gora nu:</h3><ul><li>Skapa din profil</li><li>Utforska medlemskatalogen</li><li>Delta i evenemang</li></ul></div></div>',
  update: '<div style="max-width:600px;margin:0 auto;font-family:Arial,sans-serif;"><div style="background:#1a1a2e;padding:20px 24px;"><span style="color:#dc2626;font-weight:700;font-size:18px;">FC</span> <span style="color:#94a3b8;font-size:13px;">Medlemsuppdatering</span></div><div style="padding:32px 24px;background:#fff;"><h2>Uppdatering</h2><p>Hej medlemmar!</p><p>Innehall...</p></div></div>',
  minimal: '<div style="max-width:600px;margin:0 auto;padding:32px;font-family:Arial,sans-serif;"><h2 style="color:#1e293b;">FilmCentrum</h2><p style="color:#374151;line-height:1.7;">Meddelande...</p><p style="margin-top:24px;color:#64748b;font-size:12px;">FilmCentrum Riks</p></div>'
};

var savedTmpl = localStorage.getItem('nl_template');
var initContent = savedTmpl || templates.news;
if (savedTmpl) localStorage.removeItem('nl_template');

var nlEditor = grapesjs.init({
  container: '#nlEditor', height: '450px', storageManager: false,
  plugins: ['gjs-preset-webpage'],
  pluginsOpts: { 'gjs-preset-webpage': { blocksBasicOpts: { flexGrid: true }, navbarOpts: false, countdownOpts: false, formsOpts: false } },
  assetManager: { upload: BASE_URL + '/api/upload', uploadName: 'file', credentials: 'same-origin' },
  components: initContent
});

function loadTmpl(name) { if (templates[name]) nlEditor.setComponents(templates[name]); }

function nlAi(action) {
  var text = action === 'generate' ? document.getElementById('nlAiPrompt').value : nlEditor.getHtml();
  if (!text || text.length < 3) { alert(action === 'generate' ? 'Type a prompt' : 'Add content first'); return; }
  document.querySelectorAll('.ai-btn').forEach(function(b){b.classList.add('loading');});
  fetch(BASE_URL + '/api/ai/write', {
    method:'POST', headers:{'Content-Type':'application/json'}, credentials:'same-origin',
    body: JSON.stringify({ action: action, text: action !== 'generate' ? text : undefined, prompt: action === 'generate' ? text : undefined })
  }).then(function(r){return r.json();}).then(function(d) {
    document.querySelectorAll('.ai-btn').forEach(function(b){b.classList.remove('loading');});
    if (d.result) { if (action === 'generate') { nlEditor.addComponents(d.result); document.getElementById('nlAiPrompt').value=''; } else { nlEditor.setComponents(d.result); } }
    else alert(d.error || 'AI error');
  }).catch(function(e) { document.querySelectorAll('.ai-btn').forEach(function(b){b.classList.remove('loading');}); alert('Error: '+e.message); });
}

function showPreview() {
  var html = nlEditor.getHtml(); var css = nlEditor.getCss();
  document.getElementById('previewBody').innerHTML = (css ? '<style>'+css+'</style>' : '') + html;
  document.getElementById('previewModal').classList.add('show');
}
function closePreview() { document.getElementById('previewModal').classList.remove('show'); }

function confirmSend() {
  var html = nlEditor.getHtml(); var css = nlEditor.getCss();
  document.getElementById('nlHidden').value = css ? '<style>'+css+'</style>'+html : html;
  return confirm('Send this newsletter?');
}
document.getElementById('composeForm').addEventListener('submit', function() {
  var html = nlEditor.getHtml(); var css = nlEditor.getCss();
  document.getElementById('nlHidden').value = css ? '<style>'+css+'</style>'+html : html;
});
</script>
