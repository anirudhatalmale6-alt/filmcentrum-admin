<style>
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-bottom: 32px; }
  .stat-card { background: #1e293b; border-radius: 10px; padding: 24px; border: 1px solid #334155; transition: transform 0.2s; }
  .stat-card:hover { transform: translateY(-2px); }
  .stat-card .label { font-size: 13px; color: #64748b; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
  .stat-card .value { font-size: 36px; font-weight: 700; color: #f1f5f9; }
  .stat-card.accent .value { color: #dc2626; }
  .stat-card .sub { font-size: 12px; color: #475569; margin-top: 6px; }
  .welcome-section { margin-bottom: 28px; }
  .welcome-section h2 { font-size: 20px; color: #f1f5f9; margin-bottom: 6px; }
  .welcome-section p { color: #64748b; font-size: 14px; }
</style>

<div class="welcome-section">
  <h2>Welcome back</h2>
  <p>Here is an overview of your FilmCentrum membership data.</p>
</div>

<div class="stats-grid">
  <div class="stat-card accent">
    <div class="label">Total Members</div>
    <div class="value"><%= stats.total_members %></div>
    <div class="sub">All registered members</div>
  </div>
  <div class="stat-card">
    <div class="label">Active</div>
    <div class="value"><%= stats.active_members %></div>
    <div class="sub">Approved members</div>
  </div>
  <div class="stat-card">
    <div class="label">Pending</div>
    <div class="value"><%= stats.pending_members %></div>
    <div class="sub">Awaiting review</div>
  </div>
  <div class="stat-card">
    <div class="label">Pending Approval</div>
    <div class="value"><%= stats.pending_approval %></div>
    <div class="sub">Profile not approved</div>
  </div>
  <div class="stat-card">
    <div class="label">Public Profiles</div>
    <div class="value"><%= stats.public_profiles %></div>
    <div class="sub">Visible in directory</div>
  </div>
  <div class="stat-card">
    <div class="label">Newsletter</div>
    <div class="value"><%= stats.newsletter_subscribers %></div>
    <div class="sub">Active subscribers</div>
  </div>
  <div class="stat-card">
    <div class="label">Pages</div>
    <div class="value"><%= stats.total_pages %></div>
    <div class="sub">CMS pages</div>
  </div>
  <div class="stat-card">
    <div class="label">Paid</div>
    <div class="value"><%= stats.paid_members %></div>
    <div class="sub">Payment confirmed</div>
  </div>
</div>
