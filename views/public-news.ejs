<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nyheter - FilmCentrum Riks</title>
  <link href="https://fonts.googleapis.com/css2?family=Special+Elite&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
                *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#fafafa;color:#1e293b}
    .header{background:#fff;box-shadow:0 1px 2px 0 rgba(0,0,0,.05);position:sticky;top:0;z-index:50}
    .header-inner{max-width:80rem;margin:0 auto;padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:64px}
    @media(min-width:768px){.header-inner{height:80px}}
    .logo-link{display:flex;align-items:center;gap:12px;text-decoration:none}
    .logo-img{height:48px;width:auto}
    .logo-text{font-family:'Special Elite','Courier New',monospace;color:#c0392b;font-size:1.125rem;font-weight:700;letter-spacing:0.025em}
    .main-nav{display:none;align-items:center;gap:4px}
    @media(min-width:1024px){.main-nav{display:flex}}
    .main-nav a{color:#374151;text-decoration:none;font-size:0.875rem;font-weight:500;padding:8px 12px;border-radius:6px;transition:color 0.15s,background-color 0.15s;white-space:nowrap}
    .main-nav a:hover{color:#c0392b;background:#f9fafb}
    .header-actions{display:flex;align-items:center;gap:12px}
    .fc-dist-btn{display:none;background:#c0392b;color:#fff;text-decoration:none;font-size:0.875rem;font-weight:500;padding:8px 16px;border-radius:6px;transition:background 0.15s}
    @media(min-width:768px){.fc-dist-btn{display:inline-flex}}
    .fc-dist-btn:hover{background:#a93226}
    .mobile-menu-btn{display:block;padding:8px;color:#4b5563;background:none;border:none;cursor:pointer}
    .mobile-menu-btn:hover{color:#111827}
    @media(min-width:1024px){.mobile-menu-btn{display:none}}
    .mobile-nav{display:none;border-top:1px solid #e5e7eb;padding:16px 0}
    .mobile-nav.show{display:block}
    @media(min-width:1024px){.mobile-nav{display:none!important}}
    .mobile-nav a{display:block;padding:8px 12px;font-size:1rem;font-weight:500;color:#374151;text-decoration:none;border-radius:6px}
    .mobile-nav a:hover{background:#f9fafb;color:#c0392b}
    .hero{background:linear-gradient(135deg,#1a1a2e,#16213e);padding:48px 32px;text-align:center;color:#fff}
    .hero h1{font-family:'Playfair Display',serif;font-size:36px;margin-bottom:8px}
    .hero p{color:#94a3b8;font-size:15px}
    .container{max-width:900px;margin:0 auto;padding:32px 24px}
    .article-card{background:#fff;border-radius:12px;padding:28px;border:1px solid #e2e8f0;margin-bottom:20px;transition:box-shadow 0.2s}
    .article-card:hover{box-shadow:0 4px 16px rgba(0,0,0,0.06)}
    .article-card .meta{font-size:12px;color:#64748b;margin-bottom:8px;display:flex;gap:12px}
    .article-card .meta .cat{background:#fef2f2;color:#dc2626;padding:2px 8px;border-radius:10px;font-weight:500;font-size:11px}
    .article-card h2{font-size:20px;margin-bottom:8px}
    .article-card h2 a{color:#1e293b;text-decoration:none}
    .article-card h2 a:hover{color:#dc2626}
    .article-card .excerpt{color:#475569;font-size:14px;line-height:1.6}
    .article-card .read-more{display:inline-block;margin-top:12px;color:#dc2626;font-size:13px;font-weight:600;text-decoration:none}
    .article-card .read-more:hover{text-decoration:underline}
    .no-articles{text-align:center;padding:48px;color:#64748b}
    .footer{background:#1a1a2e;padding:24px 32px;text-align:center;color:#64748b;font-size:12px;margin-top:48px}
    .footer a{color:#dc2626;text-decoration:none}
  </style>
</head>
<body>
    <div class="header">
    <div class="header-inner">
      <a href="/filmcentrum/" class="logo-link">
        <img src="/filmcentrum/fc-logo.png" alt="FilmCentrum" class="logo-img">
        <span class="logo-text">FILMCENTRUM RIKS</span>
      </a>
      <nav class="main-nav">
        <a href="/filmcentrum/">Hem</a>
        <a href="/filmcentrum/om-oss">Om oss</a>
        <a href="/filmcentrum/openthedoors">FC OpenTheDoors</a>
        <a href="/filmcentrum/medlemskap">Medlemskap</a>
        <a href="/filmcentrum/nyheter">Nyheter</a>
        <a href="/filmcentrum/kontakt">Kontakta oss</a>
        <a href="/filmcentrum/login">Logga in</a>
        <a href="/fc/">Filmkatalog</a>
      </nav>
      <div class="header-actions">
        <a href="/fc/" class="fc-dist-btn">FC Distribution</a>
        <button class="mobile-menu-btn" onclick="document.querySelector('.mobile-nav').classList.toggle('show')" aria-label="Meny">
          <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
    <div class="mobile-nav">
      <a href="/filmcentrum/">Hem</a>
      <a href="/filmcentrum/om-oss">Om oss</a>
      <a href="/filmcentrum/openthedoors">FC OpenTheDoors</a>
      <a href="/filmcentrum/medlemskap">Medlemskap</a>
      <a href="/filmcentrum/nyheter">Nyheter</a>
      <a href="/filmcentrum/kontakt">Kontakta oss</a>
      <a href="/filmcentrum/login">Logga in</a>
      <a href="/fc/">Filmkatalog</a>
    </div>
  </div>

  <div class="hero"><h1>Nyheter</h1><p>Senaste nytt fran FilmCentrum Riks</p></div>
  <div class="container">
    <% if (articles.length === 0) { %><div class="no-articles">Inga nyheter annu.</div><% } %>
    <% articles.forEach(function(a) { %>
      <div class="article-card">
        <div class="meta">
          <span class="cat"><%= a.category %></span>
          <span><%= a.published_at ? new Date(a.published_at).toLocaleDateString('sv-SE') : '' %></span>
        </div>
        <h2><a href="/filmcentrum/nyheter/<%= a.slug %>"><%= a.title_sv || a.title_en %></a></h2>
        <% if (a.excerpt_sv) { %><p class="excerpt"><%= a.excerpt_sv %></p><% } %>
        <a href="/filmcentrum/nyheter/<%= a.slug %>" class="read-more">Las mer &rarr;</a>
      </div>
    <% }); %>
  </div>
  <div class="footer">&copy; 2026 <a href="/filmcentrum/">FilmCentrum Riks</a></div>
<script src="/filmcentrum/chatbot.js"></script>
</body>
</html>
