<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Bli medlem - FilmCentrum Riks</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f8fafc; color: #1e293b; }
    .nav { background: #1a1a2e; padding: 16px 32px; display: flex; align-items: center; gap: 16px; }
    .nav img { height: 40px; }
    .nav h1 { color: #dc2626; font-size: 18px; font-weight: 700; letter-spacing: 1px; }
    .nav-links { margin-left: auto; display: flex; gap: 20px; }
    .nav-links a { color: #cbd5e1; text-decoration: none; font-size: 14px; }
    .nav-links a:hover { color: #fff; }
    .container { max-width: 640px; margin: 40px auto; padding: 0 16px; }
    .card { background: #fff; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); padding: 40px; }
    .card h2 { font-size: 24px; text-align: center; margin-bottom: 8px; }
    .card .subtitle { text-align: center; color: #64748b; font-size: 14px; margin-bottom: 28px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .form-row.full { grid-template-columns: 1fr; }
    .form-group { display: flex; flex-direction: column; }
    .form-group label { font-size: 13px; font-weight: 600; color: #334155; margin-bottom: 4px; }
    .form-group label .req { color: #dc2626; }
    .form-group input, .form-group textarea, .form-group select { padding: 10px 14px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; color: #1e293b; outline: none; transition: border 0.2s; }
    .form-group input:focus, .form-group textarea:focus { border-color: #dc2626; box-shadow: 0 0 0 3px rgba(220,38,38,0.1); }
    .form-group textarea { resize: vertical; min-height: 80px; font-family: inherit; }
    .btn-submit { display: block; width: 100%; padding: 12px; background: #dc2626; color: #fff; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; margin-top: 8px; transition: background 0.2s; }
    .btn-submit:hover { background: #b91c1c; }
    .divider { border: none; border-top: 1px solid #e2e8f0; margin: 20px 0; }
    .section-title { font-size: 14px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
    .error-box { background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; color: #991b1b; font-size: 14px; margin-bottom: 20px; }
    .success-box { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; padding: 28px; text-align: center; }
    .success-box h3 { color: #166534; font-size: 20px; margin-bottom: 12px; }
    .success-box p { color: #15803d; font-size: 14px; margin-bottom: 8px; }
    .success-box .ref { background: #dcfce7; padding: 8px 16px; border-radius: 8px; font-family: monospace; font-size: 16px; font-weight: 700; color: #166534; display: inline-block; margin: 8px 0; }
    .payment-info { background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; padding: 16px; margin-top: 16px; text-align: left; }
    .payment-info h4 { color: #92400e; margin-bottom: 8px; }
    .payment-info p { color: #78350f; font-size: 13px; margin-bottom: 4px; }
    .back-link { display: block; text-align: center; margin-top: 20px; color: #64748b; text-decoration: none; font-size: 14px; }
    .back-link:hover { color: #dc2626; }
    @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } .card { padding: 24px; } }
  </style>
</head>
<body>
  <div class="nav">
    <img src="/filmcentrum/admin/uploads/wp/Kopia-av-Filmcentrum_logotyp_CMYK-1.png" alt="FC" style="height:36px;border-radius:6px;">
    <h1>FILMCENTRUM RIKS</h1>
    <div class="nav-links">
      <a href="/filmcentrum/">Hem</a>
      <a href="/filmcentrum/om-oss">Om oss</a>
      <a href="/filmcentrum/nyheter">Nyheter</a>
      <a href="/filmcentrum/login">Logga in</a>
    </div>
  </div>

  <div class="container">
    <div class="card">
      <h2>Ansokan om medlemskap</h2>
      <p class="subtitle">Fyll i dina uppgifter for att ansoka om medlemskap i FilmCentrum Riks.</p>

      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <% if (success) { %>
        <div class="success-box">
          <h3>Ansokan mottagen!</h3>
          <p>Tack for din ansokan. Betala medlemsavgiften for att slutfora registreringen.</p>
          <div class="payment-info">
            <h4>Betalning: <%= success.amount %> kr</h4>
            <p><strong>Swish:</strong> <%= swish %></p>
            <p><strong>BankGiro:</strong> <%= bankgiro %></p>
            <p><strong>Meddelande:</strong> Ditt namn och personnummer</p>
          </div>
          <p style="margin-top:16px;font-size:13px;color:#64748b;">Nar betalningen ar registrerad aktiveras ditt medlemskap.</p>
        </div>
        <a href="/filmcentrum/login" class="back-link">Logga in med ditt konto</a>
      <% } else { %>
        <form method="POST" action="/filmcentrum/bli-medlem">
          <div class="section-title">Personuppgifter</div>
          <div class="form-row">
            <div class="form-group">
              <label>Namn <span class="req">*</span></label>
              <input type="text" name="name" required placeholder="Ditt fullstandiga namn">
            </div>
            <div class="form-group">
              <label>Personnummer <span class="req">*</span></label>
              <input type="text" name="personnummer" required placeholder="YYYYMMDD-XXXX">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Yrke / Profession <span class="req">*</span></label>
              <input type="text" name="profession" required placeholder="t.ex. Regissor, Fotograf, Producent">
            </div>
            <div class="form-group">
              <label>E-post <span class="req">*</span></label>
              <input type="email" name="email" required placeholder="din@epost.se">
            </div>
          </div>
          <div class="form-row full">
            <div class="form-group">
              <label>Telefon</label>
              <input type="text" name="phone" placeholder="070-123 45 67">
            </div>
          </div>

          <hr class="divider">
          <div class="section-title">Losenord</div>
          <div class="form-row">
            <div class="form-group">
              <label>Losenord <span class="req">*</span></label>
              <input type="password" name="password" required minlength="6" placeholder="Minst 6 tecken">
            </div>
            <div class="form-group">
              <label>Bekrafta losenord <span class="req">*</span></label>
              <input type="password" name="confirm_password" required minlength="6" placeholder="Upprepa losenord">
            </div>
          </div>

          <hr class="divider">
          <div class="section-title">Om dig</div>
          <div class="form-row full">
            <div class="form-group">
              <label>Om dig och dina filmer</label>
              <textarea name="bio" placeholder="Beratta kort om dig sjalv och vilka filmer du har gjort..."></textarea>
            </div>
          </div>
          <div class="form-row full">
            <div class="form-group">
              <label>Portfolio / Webbplats</label>
              <input type="url" name="portfolio_url" placeholder="https://din-webbplats.se">
            </div>
          </div>

          <button type="submit" class="btn-submit">Skicka ansokan</button>
          <p style="text-align:center;font-size:12px;color:#94a3b8;margin-top:12px;">Medlemsavgift: <%= amount %> kr/ar. Betalas via Swish eller BankGiro efter registrering.</p>
        </form>
      <% } %>
    </div>
    <a href="/filmcentrum/" class="back-link">Tillbaka till startsidan</a>
  </div>
</body>
</html>