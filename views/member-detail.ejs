<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= member.name %> - FilmCentrum Riks</title>
  <link href="https://fonts.googleapis.com/css2?family=Special+Elite&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#fafafa;color:#1e293b}
    .header{background:#fff;box-shadow:0 1px 2px 0 rgba(0,0,0,.05);position:sticky;top:0;z-index:50}
    .header-inner{max-width:80rem;margin:0 auto;padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:64px}
    @media(min-width:768px){.header-inner{height:80px}}
    .logo-link{display:flex;align-items:center;gap:12px;text-decoration:none}
    .logo-img{height:48px;width:auto}
    .logo-text{font-family:'Special Elite','Courier New',monospace;color:#c0392b;font-size:1.125rem;font-weight:700;letter-spacing:0.025em}
    .main-nav{display:none;align-items:center;gap:4px}
    @media(min-width:1024px){.main-nav{display:flex}}
    .main-nav a{color:#374151;text-decoration:none;font-size:0.875rem;font-weight:500;padding:8px 12px;border-radius:6px;transition:color 0.15s,background-color 0.15s;white-space:nowrap}
    .main-nav a:hover{color:#c0392b;background:#f9fafb}
    .header-actions{display:flex;align-items:center;gap:12px}
    .fc-dist-btn{display:none;background:#c0392b;color:#fff;text-decoration:none;font-size:0.875rem;font-weight:500;padding:8px 16px;border-radius:6px}
    @media(min-width:768px){.fc-dist-btn{display:inline-flex}}
    .mobile-menu-btn{display:block;padding:8px;color:#4b5563;background:none;border:none;cursor:pointer}
    @media(min-width:1024px){.mobile-menu-btn{display:none}}
    .container{max-width:800px;margin:0 auto;padding:32px 24px}
    .back{display:inline-block;color:#64748b;text-decoration:none;font-size:14px;margin-bottom:20px}
    .back:hover{color:#c0392b}
    .profile-card{background:#fff;border-radius:16px;padding:40px;border:1px solid #e2e8f0;box-shadow:0 4px 16px rgba(0,0,0,0.04)}
    .profile-top{display:flex;gap:24px;align-items:center;margin-bottom:24px}
    .profile-photo{width:100px;height:100px;border-radius:50%;object-fit:cover}
    .profile-photo-placeholder{width:100px;height:100px;border-radius:50%;background:#c0392b;color:#fff;display:flex;align-items:center;justify-content:center;font-size:40px;font-weight:700}
    .profile-name{font-size:28px;font-weight:700;font-family:'Playfair Display',serif}
    .profile-headline{color:#c0392b;font-size:16px;font-weight:500;margin-top:4px}
    .profile-location{color:#64748b;font-size:14px;margin-top:4px}
    .profile-section{margin-top:24px;padding-top:20px;border-top:1px solid #f1f5f9}
    .profile-section h3{font-size:16px;font-weight:600;color:#1e293b;margin-bottom:12px}
    .profile-section p{color:#475569;line-height:1.7;font-size:15px}
    .profile-tags{display:flex;flex-wrap:wrap;gap:6px}
    .profile-tag{padding:4px 12px;background:#fef2f2;color:#c0392b;border-radius:16px;font-size:13px;font-weight:500}
    .profile-links{display:flex;flex-wrap:wrap;gap:12px;margin-top:16px}
    .profile-links a{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:#f1f5f9;border-radius:8px;color:#1e293b;text-decoration:none;font-size:13px;font-weight:500;transition:background 0.15s}
    .profile-links a:hover{background:#e2e8f0}
    .gallery{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-top:12px}
    .gallery img{width:100%;border-radius:8px;aspect-ratio:1;object-fit:cover}
    .footer{background:#1a1a2e;padding:24px 32px;text-align:center;color:#64748b;font-size:12px;margin-top:48px}
    .footer a{color:#dc2626;text-decoration:none}
    @media(max-width:600px){.profile-top{flex-direction:column;text-align:center}.profile-card{padding:24px}}
  </style>
</head>
<body>
  <div class="header">
    <div class="header-inner">
      <a href="/filmcentrum/" class="logo-link">
        <img src="/filmcentrum/fc-logo.png" alt="FC" class="logo-img">
        <span class="logo-text">FILMCENTRUM RIKS</span>
      </a>
      <nav class="main-nav">
        <a href="/filmcentrum/">Hem</a>
        <a href="/filmcentrum/om-oss">Om oss</a>
        <a href="/filmcentrum/openthedoors">FC OpenTheDoors</a>
        <a href="/filmcentrum/medlemskap">Medlemskap</a>
        <a href="/filmcentrum/nyheter">Nyheter</a>
        <a href="/filmcentrum/kontakt">Kontakta oss</a>
        <a href="/filmcentrum/login">Logga in</a>
        <a href="/fc/">Filmkatalog</a>
        <a href="/fai/">Festival AI</a>
        <a href="/filmcentrum/events">Kalender</a>
      </nav>
      <div class="header-actions">
        <a href="/fc/" class="fc-dist-btn">FC Distribution</a>
      </div>
    </div>
  </div>

  <div class="container">
    <a href="/filmcentrum/members" class="back">&larr; Tillbaka till medlemskatalogen</a>
    <div class="profile-card">
      <div class="profile-top">
        <% if (member.profile_photo) { %>
          <img src="<%= member.profile_photo %>" class="profile-photo" alt="">
        <% } else { %>
          <div class="profile-photo-placeholder"><%= (member.name || 'M').charAt(0) %></div>
        <% } %>
        <div>
          <div class="profile-name"><%= member.name %></div>
          <% if (member.headline || member.profession) { %><div class="profile-headline"><%= member.headline || member.profession %></div><% } %>
          <% if (member.city) { %><div class="profile-location"><%= member.city %><% if (member.country && member.country !== 'SE') { %>, <%= member.country %><% } %></div><% } %>
        </div>
      </div>

      <% if (member.biography) { %>
      <div class="profile-section">
        <h3>Om</h3>
        <p><%= member.biography %></p>
      </div>
      <% } %>

      <% if (typeof branches !== 'undefined' && branches.length > 0) { %>
      <div class="profile-section">
        <h3>Filmgrenar</h3>
        <div class="profile-tags">
          <% branches.forEach(function(b) { %><span class="profile-tag"><%= b.name_sv || b.name %><% if (b.is_primary) { %> (primat)<% } %></span><% }); %>
        </div>
      </div>
      <% } %>

      <% if (member.film_type) { %>
      <div class="profile-section">
        <h3>Filmtyp</h3>
        <p><%= member.film_type %></p>
      </div>
      <% } %>

      <% if (member.profession) { %>
      <div class="profile-section">
        <h3>Profession</h3>
        <p><%= member.profession %></p>
      </div>
      <% } %>

      <% if (member.primary_roles) { %>
      <div class="profile-section">
        <h3>Roller</h3>
        <p><%= member.primary_roles %></p>
      </div>
      <% } %>

      <% if (member.skills || member.technical_skills) { %>
      <div class="profile-section">
        <h3>Kompetenser</h3>
        <div class="profile-tags">
          <% if (member.skills) { member.skills.split(',').forEach(function(s) { if(s.trim()) { %><span class="profile-tag"><%= s.trim() %></span><% } }); } %>
          <% if (member.technical_skills) { member.technical_skills.split(',').forEach(function(s) { if(s.trim()) { %><span class="profile-tag"><%= s.trim() %></span><% } }); } %>
        </div>
      </div>
      <% } %>

      <% if (typeof education !== 'undefined' && education.length > 0) { %>
      <div class="profile-section">
        <h3>Utbildning</h3>
        <% education.forEach(function(e) { %>
          <div style="margin-bottom:12px;padding:12px;background:#f8fafc;border-radius:8px;">
            <div style="font-weight:600;"><%= e.institution %></div>
            <% if (e.qualification || e.field_of_study) { %><div style="color:#475569;font-size:14px;"><%= e.qualification %><% if (e.field_of_study) { %> - <%= e.field_of_study %><% } %></div><% } %>
            <% if (e.start_year) { %><div style="color:#94a3b8;font-size:13px;"><%= e.start_year %><% if (e.end_year) { %> - <%= e.end_year %><% } %></div><% } %>
          </div>
        <% }); %>
      </div>
      <% } %>

      <% if (typeof experience !== 'undefined' && experience.length > 0) { %>
      <div class="profile-section">
        <h3>Erfarenhet / Filmer</h3>
        <% experience.forEach(function(ex) { %>
          <div style="margin-bottom:12px;padding:12px;background:#f8fafc;border-radius:8px;">
            <div style="font-weight:600;"><%= ex.project_title %></div>
            <% if (ex.role) { %><div style="color:#c0392b;font-size:14px;"><%= ex.role %></div><% } %>
            <% if (ex.project_type || ex.production_company) { %><div style="color:#475569;font-size:14px;"><%= ex.project_type || '' %><% if (ex.production_company) { %> - <%= ex.production_company %><% } %></div><% } %>
            <% if (ex.year) { %><div style="color:#94a3b8;font-size:13px;"><%= ex.year %></div><% } %>
            <% if (ex.description) { %><div style="color:#475569;font-size:14px;margin-top:4px;"><%= ex.description %></div><% } %>
            <% if (ex.link) { %><a href="<%= ex.link %>" target="_blank" style="color:#1d4ed8;font-size:13px;">Visa &rarr;</a><% } %>
          </div>
        <% }); %>
      </div>
      <% } %>

      <% if (member.awards) { %>
      <div class="profile-section">
        <h3>Utmarkelser</h3>
        <p><%= member.awards %></p>
      </div>
      <% } %>

      <% if (member.festival_selections) { %>
      <div class="profile-section">
        <h3>Festivalurval</h3>
        <p><%= member.festival_selections %></p>
      </div>
      <% } %>

      <% if (member.notable_credits) { %>
      <div class="profile-section">
        <h3>Namnvarda produktioner</h3>
        <p><%= member.notable_credits %></p>
      </div>
      <% } %>

      <% if (member.equipment) { %>
      <div class="profile-section">
        <h3>Utrustning</h3>
        <p><%= member.equipment %></p>
      </div>
      <% } %>

      <% if (member.languages_spoken) { %>
      <div class="profile-section">
        <h3>Sprak</h3>
        <p><%= member.languages_spoken %></p>
      </div>
      <% } %>

      <% if (member.years_experience || member.career_stage) { %>
      <div class="profile-section">
        <h3>Karriar</h3>
        <% if (member.years_experience) { %><p>Erfarenhet: <%= member.years_experience %> ar</p><% } %>
        <% if (member.career_stage) { %><p>Karriarsteg: <%= member.career_stage %></p><% } %>
        <% if (member.availability) { %><p>Tillganglighet: <%= member.availability %></p><% } %>
      </div>
      <% } %>

      <% if (member.guild_memberships || member.associations) { %>
      <div class="profile-section">
        <h3>Medlemskap & Foreningar</h3>
        <% if (member.guild_memberships) { %><p><%= member.guild_memberships %></p><% } %>
        <% if (member.associations) { %><p><%= member.associations %></p><% } %>
      </div>
      <% } %>

      <div class="profile-links">
        <% if (member.website) { %><a href="<%= member.website %>" target="_blank">Webbplats</a><% } %>
        <% if (member.imdb_link) { %><a href="<%= member.imdb_link %>" target="_blank">IMDb</a><% } %>
        <% if (member.showreel_url) { %><a href="<%= member.showreel_url %>" target="_blank">Showreel</a><% } %>
        <% if (member.social_media) { %><a href="<%= member.social_media %>" target="_blank">Sociala medier</a><% } %>
        <% if (member.instagram) { %><a href="<%= member.instagram %>" target="_blank">Instagram</a><% } %>
        <% if (member.linkedin) { %><a href="<%= member.linkedin %>" target="_blank">LinkedIn</a><% } %>
        <% if (member.twitter) { %><a href="<%= member.twitter %>" target="_blank">Twitter</a><% } %>
        <% if (member.vimeo_channel) { %><a href="<%= member.vimeo_channel %>" target="_blank">Vimeo</a><% } %>
        <% if (member.youtube_channel) { %><a href="<%= member.youtube_channel %>" target="_blank">YouTube</a><% } %>
      </div>

      <% if (typeof media !== 'undefined' && media.length > 0) { %>
      <div class="profile-section">
        <h3>Galleri</h3>
        <div class="gallery">
          <% media.forEach(function(img) { %>
            <img src="<%= img.url %>" alt="<%= img.caption || '' %>">
          <% }); %>
        </div>
      </div>
      <% } %>

      <% if (member.phone || member.email) { %>
      <div class="profile-section">
        <h3>Kontakt</h3>
        <% if (member.email) { %><p>E-post: <a href="mailto:<%= member.email %>" style="color:#c0392b"><%= member.email %></a></p><% } %>
        <% if (member.phone) { %><p>Telefon: <%= member.phone %></p><% } %>
        <% if (member.city) { %><p>Stad: <%= member.city %><% if (member.country) { %>, <%= member.country %><% } %></p><% } %>
      </div>
      <% } %>
    </div>
  </div>

  <div class="footer">
    &copy; 2026 <a href="/filmcentrum/">FilmCentrum Riks</a>
  </div>
<script>
(function(){
  var cal = document.createElement('div');
  cal.id = 'fc-events-sidebar';
  cal.innerHTML = '<div style="position:fixed;top:100px;right:16px;width:280px;max-height:70vh;overflow-y:auto;background:#fff;border-radius:12px;box-shadow:0 4px 24px rgba(0,0,0,0.1);border:1px solid #e2e8f0;z-index:40;font-family:Inter,sans-serif;display:none;" id="evSidebar"><div style="padding:14px 16px;border-bottom:1px solid #f1f5f9;display:flex;justify-content:space-between;align-items:center;"><strong style="font-size:14px;color:#1e293b;">Kommande evenemang</strong><span style="cursor:pointer;font-size:18px;color:#94a3b8;" onclick="document.getElementById(\'evSidebar\').style.display=\'none\';document.getElementById(\'evToggle\').style.display=\'flex\';">&times;</span></div><div id="evList" style="padding:12px 16px;"></div><div style="padding:12px 16px;border-top:1px solid #f1f5f9;text-align:center;"><a href="/fai/" style="color:#c0392b;text-decoration:none;font-size:13px;font-weight:500;">Festival AI &rarr;</a></div></div>';
  // Auto-show sidebar on desktop
  if(window.innerWidth > 1024) { document.getElementById('evSidebar').style.display='block'; document.getElementById('evToggle').style.display='none'; loadEvents(); }
  cal.innerHTML += '<div id="evToggle" style="position:fixed;top:100px;right:16px;width:44px;height:44px;background:#c0392b;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 12px rgba(192,57,43,0.3);z-index:40;" onclick="document.getElementById(\'evSidebar\').style.display=\'block\';this.style.display=\'none\';loadEvents();"><svg width="22" height="22" fill="#fff" viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z"/></svg></div>';
  document.body.appendChild(cal);
  window.loadEvents = function() {
    fetch('/filmcentrum/admin/api/public/events').then(function(r){return r.json()}).then(function(d){
      var html = '';
      if (d.events && d.events.length > 0) {
        d.events.slice(0, 8).forEach(function(e){
          var cat = e.category === 'festival' ? '#3b82f6' : e.category === 'workshop' ? '#10b981' : '#8b5cf6';
          html += '<div style="padding:8px 0;border-bottom:1px solid #f8fafc;"><div style="display:flex;gap:8px;align-items:flex-start;"><div style="min-width:40px;text-align:center;background:#fef2f2;border-radius:6px;padding:4px;"><div style="font-size:10px;color:#c0392b;font-weight:600;">' + (e.event_date||'').substring(5,7) + '</div><div style="font-size:16px;font-weight:700;color:#1e293b;">' + (e.event_date||'').substring(8,10) + '</div></div><div><div style="font-size:13px;font-weight:600;color:#1e293b;">' + e.title + '</div><div style="font-size:11px;color:#64748b;">' + (e.location||'') + '</div><span style="display:inline-block;padding:1px 6px;background:' + cat + '20;color:' + cat + ';border-radius:8px;font-size:10px;margin-top:2px;">' + e.category + '</span></div></div></div>';
        });
      } else {
        html = '<p style="color:#94a3b8;font-size:13px;text-align:center;padding:16px;">Inga kommande evenemang.</p>';
      }
      document.getElementById('evList').innerHTML = html;
    }).catch(function(){
      document.getElementById('evList').innerHTML = '<p style="color:#94a3b8;font-size:13px;">Kunde inte ladda evenemang.</p>';
    });
  };
})();
</script>
<script src="/filmcentrum/chatbot.js"></script>
</body>
</html>