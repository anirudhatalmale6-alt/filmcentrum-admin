<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= article.title_sv || article.title_en %> - FilmCentrum Riks</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
        *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#fafafa;color:#1e293b}
    .header{background:#fff;padding:8px 24px;display:flex;justify-content:space-between;align-items:center;box-shadow:0 1px 3px 0 rgba(0,0,0,.1),0 1px 2px -1px rgba(0,0,0,.1);position:relative;z-index:10}
    .header .logo{display:flex;align-items:center;gap:10px;text-decoration:none}
    .header .logo img{height:40px}
    .header .logo span{color:#c0392b;font-size:16px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase}
    .header nav{display:flex;align-items:center;gap:2px}
    .header nav a{color:#374151;text-decoration:none;font-size:14px;font-weight:500;padding:8px 12px;border-radius:6px;transition:color 0.15s,background 0.15s}
    .header nav a:hover{color:#c0392b;background:#f9fafb}
    .header nav a.active{color:#c0392b;background:#fef2f2}
    .fc-dist-btn{background:#c0392b!important;color:#fff!important;border-radius:6px!important;padding:8px 16px!important;font-weight:600!important;font-size:13px!important}
    .fc-dist-btn:hover{background:#a93226!important}
    @media(max-width:768px){.header{flex-direction:column;gap:12px;padding:12px 16px}.header nav{flex-wrap:wrap;justify-content:center;gap:4px}}
    .container{max-width:800px;margin:0 auto;padding:40px 24px}
    .back{display:inline-block;margin-bottom:24px;color:#64748b;text-decoration:none;font-size:13px}
    .back:hover{color:#dc2626}
    .meta{font-size:13px;color:#64748b;margin-bottom:16px;display:flex;gap:12px;align-items:center}
    .meta .cat{background:#fef2f2;color:#dc2626;padding:3px 10px;border-radius:10px;font-weight:500;font-size:11px}
    h1{font-family:'Playfair Display',serif;font-size:32px;margin-bottom:20px;line-height:1.3}
    .content{font-size:16px;line-height:1.8;color:#374151}
    .content h2,.content h3{margin:24px 0 12px;color:#1e293b}
    .content p{margin-bottom:16px}
    .content ul,.content ol{padding-left:24px;margin-bottom:16px}
    .content li{margin-bottom:6px}
    .content img{max-width:100%;border-radius:8px;margin:16px 0}
    .content a{color:#dc2626}
    .footer{background:#1a1a2e;padding:24px 32px;text-align:center;color:#64748b;font-size:12px;margin-top:48px}
    .footer a{color:#dc2626;text-decoration:none}
  </style>
</head>
<body>
  <div class="header">
    <a href="/filmcentrum/" class="logo"><img src="/filmcentrum/admin/uploads/wp/Kopia-av-Filmcentrum_logotyp_CMYK-1.png" alt="FC"><span>FILMCENTRUM RIKS</span></a>
    <nav>
      <a href="/filmcentrum/">Hem</a>
      <a href="/filmcentrum/om-oss">Om oss</a>
      <a href="/filmcentrum/openthedoors">FC OpenTheDoors</a>
      <a href="/filmcentrum/medlemskap">Medlemskap</a>
      <a href="/filmcentrum/nyheter">Nyheter</a>
      <a href="/filmcentrum/kontakt">Kontakta oss</a>
      <a href="/filmcentrum/login">Logga in</a>
      <a href="/filmcentrum/members">Filmkatalog</a>
      <a href="/filmcentrum/fc" class="fc-dist-btn">FC Distribution</a>
    </nav>
  
  
  
  
  </div>
  <div class="container">
    <a href="/filmcentrum/nyheter" class="back">&larr; Tillbaka till nyheter</a>
    <div class="meta">
      <span class="cat"><%= article.category %></span>
      <span><%= article.published_at ? new Date(article.published_at).toLocaleDateString('sv-SE') : '' %></span>
    </div>
    <h1><%= article.title_sv || article.title_en %></h1>
    <% if (article.image) { %><img src="<%= article.image %>" style="width:100%;border-radius:12px;margin-bottom:24px;"><% } %>
    <div class="content"><%- article.content_sv || article.content_en || '' %></div>
  </div>
  <div class="footer">&copy; 2026 <a href="/filmcentrum/">FilmCentrum Riks</a></div>
</body>
</html>
