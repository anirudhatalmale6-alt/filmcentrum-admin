<style>
  .back{display:inline-block;margin-bottom:16px;color:#94a3b8;text-decoration:none;font-size:13px}
  .back:hover{color:#dc2626}
  .edit-card{background:#1e293b;border-radius:10px;padding:24px;border:1px solid #334155}
  .edit-card h2{font-size:18px;color:#f1f5f9;margin-bottom:20px}
  .edit-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:16px}
  .fg{display:flex;flex-direction:column}
  .fg label{font-size:12px;color:#94a3b8;margin-bottom:4px;font-weight:500}
  .fg input,.fg select,.fg textarea{padding:8px 12px;background:#0f172a;border:1px solid #334155;border-radius:6px;color:#e2e8f0;font-size:13px;outline:none}
  .fg input:focus,.fg select:focus,.fg textarea:focus{border-color:#dc2626}
  .fg textarea{min-height:120px;resize:vertical;font-family:inherit}
  .btn-save{padding:12px 32px;background:#dc2626;color:#fff;border:none;border-radius:6px;font-size:14px;font-weight:600;cursor:pointer;margin-top:16px}
  .btn-save:hover{background:#b91c1c}
  .success-msg{background:#064e3b;color:#6ee7b7;padding:12px 20px;border-radius:8px;margin-bottom:16px;font-size:14px}
  .photo-section{text-align:center;margin-bottom:20px}
  .photo-section img{width:100px;height:100px;border-radius:50%;object-fit:cover;margin-bottom:8px}
  .photo-section .ph{width:100px;height:100px;border-radius:50%;background:#334155;display:flex;align-items:center;justify-content:center;margin:0 auto 8px;font-size:36px;color:#64748b}
  .photo-upload{display:inline-block;padding:6px 16px;background:#1d4ed8;color:#fff;border-radius:6px;font-size:12px;cursor:pointer}
</style>

<a href="<%= base %>/board" class="back">&larr; Back to Board</a>

<% if (success) { %><div class="success-msg">Board member updated.</div><% } %>

<div class="edit-card">
  <h2>Edit: <%= member.name %></h2>

  <div class="photo-section">
    <% if (member.photo) { %><img src="<%= member.photo %>" alt=""><% } else { %><div class="ph"><%= (member.name||'M').charAt(0) %></div><% } %>
    <br>
    <label class="photo-upload">Upload Photo<input type="file" accept="image/*" style="display:none" onchange="uploadPhoto(this)"></label>
  </div>

  <form method="POST" action="<%= base %>/board/<%= member.id %>/edit">
    <div class="edit-grid">
      <div class="fg"><label>Name *</label><input type="text" name="name" value="<%= member.name || '' %>" required></div>
      <div class="fg"><label>Role *</label><input type="text" name="role" value="<%= member.role || '' %>" required></div>
      <div class="fg"><label>Category</label>
        <select name="category">
          <option value="ordinarie" <%= member.category === 'ordinarie' ? 'selected' : '' %>>Ordinarie</option>
          <option value="suppleant" <%= member.category === 'suppleant' ? 'selected' : '' %>>Suppleant</option>
        </select>
      </div>
      <div class="fg"><label>Title / Position</label><input type="text" name="title" value="<%= member.title || '' %>" placeholder="e.g. Film- och teaterregissor"></div>
      <div class="fg"><label>Sort Order</label><input type="number" name="sort_order" value="<%= member.sort_order || 0 %>"></div>
    </div>
    <div style="margin-top:16px">
      <div class="fg"><label>Short Description</label><input type="text" name="description" value="<%= member.description || '' %>" placeholder="Short description"></div>
    </div>
    <div style="margin-top:16px">
      <div class="fg"><label>Bio / CV</label><textarea name="bio" placeholder="Full biography, CV, film credits..."><%= member.bio || '' %></textarea></div>
    </div>
    <button type="submit" class="btn-save">Save Changes</button>
  </form>
</div>

<script>
function uploadPhoto(input) {
  var file = input.files[0];
  if (!file) return;
  var fd = new FormData();
  fd.append('file', file);
  fd.append('member_id', '<%= member.id %>');
  fetch('<%= base %>/api/board-photo', { method: 'POST', credentials: 'same-origin', body: fd })
    .then(function(r) { return r.json(); })
    .then(function(d) { if (d.success) location.reload(); else alert(d.error); })
    .catch(function(e) { alert('Error: ' + e.message); });
}
</script>
