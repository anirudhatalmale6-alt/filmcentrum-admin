<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FilmCentrum Admin</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #0f172a; color: #e2e8f0; display: flex; min-height: 100vh; }
    .sidebar { width: 240px; background: #1e293b; padding: 0; display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 10; overflow-y: auto; }
    .sidebar-header { padding: 20px; border-bottom: 1px solid #334155; text-align: center; }
    .sidebar-header h2 { color: #dc2626; font-size: 18px; font-weight: 700; letter-spacing: 1px; }
    .sidebar-header span { color: #64748b; font-size: 12px; }
    .sidebar nav { flex: 1; padding: 12px 0; }
    .sidebar nav a { display: flex; align-items: center; padding: 10px 24px; color: #94a3b8; text-decoration: none; font-size: 13px; transition: all 0.2s; border-left: 3px solid transparent; }
    .sidebar nav a:hover, .sidebar nav a.active { background: #0f172a; color: #f1f5f9; border-left-color: #dc2626; }
    .sidebar nav a svg { width: 18px; height: 18px; margin-right: 12px; fill: currentColor; flex-shrink: 0; }
    .sidebar nav .nav-section { padding: 16px 24px 6px; font-size: 10px; color: #475569; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
    .sidebar-footer { padding: 16px 24px; border-top: 1px solid #334155; }
    .sidebar-footer a { color: #64748b; text-decoration: none; font-size: 13px; }
    .sidebar-footer a:hover { color: #dc2626; }
    .main { flex: 1; margin-left: 240px; padding: 32px; min-height: 100vh; }
    .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .top-bar h1 { font-size: 24px; font-weight: 600; color: #f1f5f9; }
    .top-bar .user-info { color: #64748b; font-size: 13px; }
    @media (max-width: 768px) {
      .sidebar { width: 60px; }
      .sidebar-header h2, .sidebar-header span, .sidebar nav a span, .sidebar nav .nav-section { display: none; }
      .sidebar nav a { justify-content: center; padding: 12px; }
      .sidebar nav a svg { margin-right: 0; }
      .main { margin-left: 60px; padding: 16px; }
    }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="sidebar-header">
      <h2>FilmCentrum</h2>
      <span>Admin Panel</span>
    </div>
    <nav>
      <a href="<%= base %>/" class="<%= currentPath === base + '/' || currentPath === base ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
        <span data-i18n="admin.dashboard">Dashboard</span>
      </a>

      <div class="nav-section">Members</div>
      <a href="<%= base %>/members" class="<%= currentPath.indexOf(base + '/members') === 0 ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
        <span data-i18n="admin.members">Members</span>
      </a>
      <a href="<%= base %>/renewals" class="<%= currentPath.indexOf(base + '/renewals') === 0 ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        <span>Renewals</span>
      </a>

      <div class="nav-section">Content</div>
      <a href="<%= base %>/pages" class="<%= currentPath.indexOf(base + '/pages') === 0 ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
        <span data-i18n="admin.pages">Pages</span>
      </a>
      <a href="<%= base %>/menu" class="<%= currentPath.indexOf(base + '/menu') === 0 ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
        <span>Menu</span>
      </a>
      <a href="<%= base %>/newsletter" class="<%= currentPath.indexOf(base + '/newsletter') === 0 ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        <span data-i18n="admin.newsletter">Newsletter</span>
      </a>
      <a href="<%= base %>/articles" class="<%= currentPath.indexOf(base + '/articles') === 0 ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
        <span>News</span>
      </a>

      <div class="nav-section">System</div>
      <a href="<%= base %>/translations" class="<%= currentPath.indexOf(base + '/translations') === 0 ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M12.87 15.07l-2.54-2.51.03-.03A17.52 17.52 0 0014.07 6H17V4h-7V2H8v2H1v1.99h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z"/></svg>
        <span>Translations</span>
      </a>
      <a href="<%= base %>/theme" style="display:flex;align-items:center;gap:8px;"><span>🎨</span> Theme</a></li>
        <li><a href="<%= base %>/settings" class="<%= currentPath.indexOf(base + '/settings') === 0 ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 00.12-.61l-1.92-3.32a.49.49 0 00-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 00-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58a.49.49 0 00-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
        <span data-i18n="admin.settings">Settings</span>
      </a>
      <a href="<%= base %>/seo" class="<%= currentPath.indexOf(base + '/seo') === 0 ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
        <span>SEO & Analytics</span>
      </a>
      <a href="<%= base %>/password" class="<%= currentPath.indexOf(base + '/password') === 0 ? 'active' : '' %>">
        <svg viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
        <span>Password</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="<%= base %>/logout">&#x2192; Logout</a>
    </div>
  </aside>
  <main class="main">
    <div class="top-bar">
      <h1>FilmCentrum Admin</h1>
      <% if (typeof admin !== "undefined" && admin) { %>
        <div class="user-info" style="display:flex;align-items:center;gap:12px;"><select id="adminLang" onchange="changeAdminLang(this.value)" style="padding:4px 8px;background:#0f172a;border:1px solid #334155;border-radius:4px;color:#e2e8f0;font-size:11px;cursor:pointer;"><option value="sv">SV</option><option value="en">EN</option><option value="no">NO</option><option value="da">DA</option><option value="fi">FI</option><option value="de">DE</option><option value="es">ES</option><option value="it">IT</option><option value="ar">AR</option><option value="tr">TR</option><option value="ur">UR</option><option value="hi">HI</option></select>Logged in as <strong><%= admin %></strong></div>
      <% } %>
    </div>
    <%- body %>
  </main>
</body>
</html>
