<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Evenemang & Kalender - FilmCentrum Riks</title>
  <link href="https://fonts.googleapis.com/css2?family=Special+Elite&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#fafafa;color:#1e293b}
    .header{background:#fff;box-shadow:0 1px 2px 0 rgba(0,0,0,.05);position:sticky;top:0;z-index:50}
    .header-inner{max-width:80rem;margin:0 auto;padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:64px}
    @media(min-width:768px){.header-inner{height:80px}}
    .logo-link{display:flex;align-items:center;gap:12px;text-decoration:none}
    .logo-img{height:48px;width:auto}
    .logo-text{font-family:'Special Elite','Courier New',monospace;color:#c0392b;font-size:1.125rem;font-weight:700;letter-spacing:0.025em}
    .main-nav{display:none;align-items:center;gap:4px}
    @media(min-width:1024px){.main-nav{display:flex}}
    .main-nav a{color:#374151;text-decoration:none;font-size:0.875rem;font-weight:500;padding:8px 12px;border-radius:6px;transition:color 0.15s,background-color 0.15s;white-space:nowrap}
    .main-nav a:hover{color:#c0392b;background:#f9fafb}
    .header-actions{display:flex;align-items:center;gap:12px}
    .mobile-menu-btn{display:block;padding:8px;color:#4b5563;background:none;border:none;cursor:pointer}
    .mobile-menu-btn:hover{color:#111827}
    @media(min-width:1024px){.mobile-menu-btn{display:none}}
    .mobile-nav{display:none;border-top:1px solid #e5e7eb;padding:16px 0}
    .mobile-nav.show{display:block}
    @media(min-width:1024px){.mobile-nav{display:none!important}}
    .mobile-nav a{display:block;padding:8px 12px;font-size:1rem;font-weight:500;color:#374151;text-decoration:none;border-radius:6px}
    .mobile-nav a:hover{background:#f9fafb;color:#c0392b}
    .main-nav{display:none;align-items:center;gap:4px}
    @media(min-width:1024px){.main-nav{display:flex}}
    .fc-dist-btn{display:none;background:#c0392b;color:#fff;text-decoration:none;font-size:0.875rem;font-weight:500;padding:8px 16px;border-radius:6px}
    @media(min-width:768px){.fc-dist-btn{display:inline-flex}}
    .hero{background:linear-gradient(135deg,#1a1a2e,#16213e);padding:48px 32px;text-align:center;color:#fff}
    .hero h1{font-family:'Playfair Display',serif;font-size:36px;margin-bottom:8px}
    .hero p{color:#94a3b8;font-size:15px}
    .container{max-width:900px;margin:0 auto;padding:32px 24px}
    .event-card{background:#fff;border-radius:12px;padding:24px;border:1px solid #e2e8f0;margin-bottom:16px;display:flex;gap:20px;transition:box-shadow 0.2s}
    .event-card:hover{box-shadow:0 4px 16px rgba(0,0,0,0.06);border-color:#c0392b;transform:translateY(-2px)}
    .event-card{transition:box-shadow 0.2s,border-color 0.2s,transform 0.2s}
    .date-box{min-width:60px;text-align:center;background:#fef2f2;border-radius:10px;padding:8px;flex-shrink:0}
    .date-box .month{font-size:12px;color:#c0392b;font-weight:600;text-transform:uppercase}
    .date-box .day{font-size:28px;font-weight:700;color:#1e293b}
    .event-info h3{font-size:18px;margin-bottom:4px}
    .event-info h3 a{color:#1e293b;text-decoration:none}
    .event-info h3 a:hover{color:#c0392b}
    .event-meta{font-size:13px;color:#64748b;margin-bottom:6px}
    .event-desc{font-size:14px;color:#475569;line-height:1.6}
    .cat-badge{display:inline-block;padding:2px 10px;border-radius:12px;font-size:11px;font-weight:500;margin-left:8px}
    .cat-festival{background:#dbeafe;color:#1d4ed8}
    .cat-event{background:#ede9fe;color:#7c3aed}
    .cat-workshop{background:#d1fae5;color:#059669}
    .cat-deadline{background:#fef3c7;color:#d97706}
    .featured-star{color:#f59e0b;margin-left:4px}
    .fai-link{display:inline-flex;align-items:center;gap:8px;background:#c0392b;color:#fff;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:600;margin-top:24px}
    .fai-link:hover{background:#a93226}
    .footer{background:#1a1a2e;padding:24px 32px;text-align:center;color:#64748b;font-size:12px;margin-top:48px}
    .footer a{color:#dc2626;text-decoration:none}
    .months{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:24px}
    .months a{padding:4px 12px;background:#f1f5f9;border-radius:16px;font-size:12px;color:#475569;text-decoration:none;font-weight:500}
    .months a:hover{background:#c0392b;color:#fff}
    @media(max-width:600px){.event-card{flex-direction:column;gap:12px}}
  </style>
</head>
<body>
  <div class="header">
    <div class="header-inner">
      <a href="/filmcentrum/" class="logo-link">
        <img src="/filmcentrum/fc-logo.png" alt="FC" class="logo-img">
        <span class="logo-text">FILMCENTRUM RIKS</span>
      </a>
      <nav class="main-nav">
        <a href="/filmcentrum/">Hem</a>
        <a href="/filmcentrum/om-oss">Om oss</a>
        <a href="/filmcentrum/styrelse">Styrelse</a>
        <a href="/filmcentrum/styrelse">Styrelse</a>
      <a href="/filmcentrum/openthedoors">FC OpenTheDoors</a>
        <a href="/filmcentrum/medlemskap">Medlemskap</a>
        <a href="/filmcentrum/nyheter">Nyheter</a>
        <a href="/filmcentrum/kontakt">Kontakta oss</a>
        <a href="/filmcentrum/login">Logga in</a>
        <a href="/fai/">Festival AI</a>
        <a href="/filmcentrum/kalender">Kalender</a>
      </nav>
      <div class="header-actions">
        <a href="/fc/" class="fc-dist-btn">FC Distribution</a>
        <button class="mobile-menu-btn" onclick="document.querySelector('.mobile-nav').classList.toggle('show')" aria-label="Meny">
          <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
    <div class="mobile-nav">
      <a href="/filmcentrum/">Hem</a>
      <a href="/filmcentrum/om-oss">Om oss</a>
      <a href="/filmcentrum/styrelse">Styrelse</a>
        <a href="/filmcentrum/openthedoors">FC OpenTheDoors</a>
      <a href="/filmcentrum/medlemskap">Medlemskap</a>
      <a href="/filmcentrum/nyheter">Nyheter</a>
      <a href="/filmcentrum/kontakt">Kontakta oss</a>
      <a href="/filmcentrum/login">Logga in</a>
      <a href="/filmcentrum/kalender">Kalender</a>
      <a href="/fai/">Festival AI</a>
    </div>
  </div>

  <div class="hero">
    <h1>Evenemang & Kalender</h1>
    <p>Filmfestivaler, workshops, deadlines och evenemang for filmskapare</p>
  </div>

  <div class="container">
    <div style="text-align:center;margin-bottom:24px;">
      <a href="/fai/" class="fai-link">🎬 Festival AI - Hitta festivaler for din film &rarr;</a>
    </div>

    <% if (events.length === 0) { %>
      <p style="text-align:center;color:#64748b;padding:48px;">Inga evenemang annu.</p>
    <% } %>

    <% events.forEach(function(e) { %>
      <div class="event-card" onclick="showEvent('<%= e.title.replace(/'/g, '') %>','<%= (e.description || '').replace(/'/g, '') %>','<%= e.event_date %>','<%= e.end_date || '' %>','<%= (e.location || '').replace(/'/g, '') %>','<%= e.category %>','<%= e.link || '' %>','<%= e.fb_event_link || '' %>')" style="cursor:pointer;">
        <div class="date-box">
          <div class="month"><%= ['jan','feb','mar','apr','maj','jun','jul','aug','sep','okt','nov','dec'][parseInt((e.event_date||'').substring(5,7))-1] || '' %></div>
          <div class="day"><%= (e.event_date||'').substring(8,10) %></div>
        </div>
        <div class="event-info">
          <h3><%= e.title %>
            <span class="cat-badge cat-<%= e.category %>"><%= e.category %></span>
            <% if (e.is_featured) { %><span class="featured-star">&#9733;</span><% } %>
          </h3>
          <div class="event-meta"><%= e.location || '' %><% if (e.end_date && e.end_date !== e.event_date) { %> | <%= e.event_date %> - <%= e.end_date %><% } %></div>
          <% if (e.description) { %><div class="event-desc"><%= e.description %></div><% } %>
          <div style="margin-top:8px;">
            <% if (e.link) { %><a href="<%= e.link %>" target="_blank" style="color:#c0392b;font-size:13px;font-weight:500;text-decoration:none;" onclick="event.stopPropagation()">Visa mer &rarr;</a><% } %>
            <% if (e.fb_event_link) { %><a href="<%= e.fb_event_link %>" target="_blank" style="color:#1d4ed8;font-size:13px;font-weight:500;text-decoration:none;margin-left:12px;" onclick="event.stopPropagation()">Facebook &rarr;</a><% } %>
          </div>
        </div>
      </div>
    <% }); %>
  </div>

  <div id="eventModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.6);z-index:100;justify-content:center;align-items:center;padding:16px;" onclick="this.style.display='none'">
    <div style="background:#fff;border-radius:16px;max-width:500px;width:100%;padding:32px;position:relative;max-height:80vh;overflow-y:auto;" onclick="event.stopPropagation()">
      <span style="position:absolute;top:12px;right:16px;font-size:24px;cursor:pointer;color:#94a3b8;" onclick="document.getElementById('eventModal').style.display='none'">&times;</span>
      <div id="emDate" style="display:inline-block;background:#fef2f2;color:#c0392b;padding:4px 12px;border-radius:8px;font-size:13px;font-weight:600;margin-bottom:12px;"></div>
      <span id="emCat" style="display:inline-block;padding:4px 12px;border-radius:8px;font-size:12px;font-weight:500;margin-left:8px;"></span>
      <h2 id="emTitle" style="font-size:24px;color:#1e293b;margin:12px 0 8px;font-family:'Playfair Display',serif;"></h2>
      <p id="emLocation" style="color:#64748b;font-size:14px;margin-bottom:12px;"></p>
      <p id="emDesc" style="color:#475569;line-height:1.7;font-size:15px;margin-bottom:16px;"></p>
      <div id="emLinks" style="display:flex;gap:12px;flex-wrap:wrap;"></div>
    </div>
  </div>

  <script>
  function showEvent(title, desc, date, endDate, location, category, link, fbLink) {
    document.getElementById('emTitle').textContent = title;
    document.getElementById('emDesc').textContent = desc || 'Mer information kommer snart.';
    document.getElementById('emDate').textContent = date + (endDate && endDate !== date ? ' - ' + endDate : '');
    document.getElementById('emLocation').textContent = location ? '📍 ' + location : '';
    var catEl = document.getElementById('emCat');
    catEl.textContent = category;
    catEl.style.background = category === 'festival' ? '#dbeafe' : category === 'workshop' ? '#d1fae5' : '#ede9fe';
    catEl.style.color = category === 'festival' ? '#1d4ed8' : category === 'workshop' ? '#059669' : '#7c3aed';
    var linksHtml = '';
    if (link) linksHtml += '<a href="' + link + '" target="_blank" style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:#c0392b;color:#fff;border-radius:8px;text-decoration:none;font-weight:500;font-size:14px;">Visa mer &rarr;</a>';
    if (fbLink) linksHtml += '<a href="' + fbLink + '" target="_blank" style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:#1877f2;color:#fff;border-radius:8px;text-decoration:none;font-weight:500;font-size:14px;">Facebook Event</a>';
    if (!link && !fbLink) linksHtml = '<p style="color:#94a3b8;font-size:13px;">Ingen extern lank tillganglig.</p>';
    document.getElementById('emLinks').innerHTML = linksHtml;
    document.getElementById('eventModal').style.display = 'flex';
  }
  </script>

  <div class="footer">&copy; 2026 <a href="/filmcentrum/">FilmCentrum Riks</a></div>
  <script src="/filmcentrum/chatbot.js"></script>
</body>
</html>